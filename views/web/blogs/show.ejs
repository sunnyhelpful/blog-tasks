<%
  title = blog.title;
%>

<!-- Blog Detail View -->
<div class="li-card" style="margin-bottom: 24px;">
  <!-- Blog Header with Author Info -->
  <div class="post-header" style="padding: 20px 24px 0;">
    <div class="post-author">
      <div class="post-logo" style="background: <%= author.gradient %>; width: 56px; height: 56px; font-size: 18px;">
        <%= author.initials %>
      </div>
      <div>
        <div class="post-author-name" style="font-size: 16px;"><%= author.name %></div>
        <div class="post-author-meta" style="font-size: 13px;"><%= author.jobTitle %> at <%= author.company %></div>
        <div class="post-author-time" style="font-size: 12px; margin-top: 4px;">
          <span><%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          <span style="margin-left: 8px;">·</span>
          <span style="margin-left: 8px;"><%= Math.ceil(blog.description.split(' ').length / 200) %> min read</span>
          <i class="bi bi-globe2" style="margin-left: 8px; font-size: 12px;"></i>
        </div>
      </div>
    </div>
    <div class="post-controls">
      <button><i class="bi bi-three-dots"></i></button>
      <button><i class="bi bi-bookmark"></i></button>
    </div>
  </div>

  <!-- Blog Title -->
  <div style="padding: 16px 24px 0;">
    <h1 style="font-size: 32px; font-weight: 700; color: rgba(0,0,0,0.9); line-height: 1.25; margin-bottom: 16px;">
      <%= blog.title %>
    </h1>
  </div>

  <!-- Blog Featured Image -->
  <% if (blog.blogImages && blog.blogImages.file_path) { %>
    <div style="margin: 16px 24px 0;">
      <img 
        src="/public/storage/<%= blog.blogImages.file_path %>" 
        alt="<%= blog.title %>"
        style="width: 100%; max-height: 500px; object-fit: cover; border-radius: 8px;"
      >
      <% if (blog.blogImages.original_file_name) { %>
        <div style="font-size: 12px; color: rgba(0,0,0,0.6); margin-top: 8px; text-align: center;">
          <%= blog.blogImages.original_file_name %>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Blog Content -->
  <div style="padding: 24px;">
    <div style="font-size: 16px; color: rgba(0,0,0,0.9); line-height: 1.6;">
      <p style="white-space: pre-wrap; word-wrap: break-word;"><%= blog.description %></p>
    </div>
  </div>

  <!-- Blog Actions -->
  <div style="border-top: 1px solid rgba(0,0,0,0.08); padding: 12px 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div style="display: flex; gap: 24px;">
        <button class="post-action-btn" id="likeBtn">
          <i class="bi bi-hand-thumbs-up"></i> Like
        </button>
        <button class="post-action-btn">
          <i class="bi bi-chat"></i> Comment
        </button>
        <button class="post-action-btn">
          <i class="bi bi-repeat"></i> Repost
        </button>
        <button class="post-action-btn">
          <i class="bi bi-send"></i> Send
        </button>
      </div>
      <div>
        <button class="post-action-btn">
          <i class="bi bi-share"></i> Share
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Related Posts Section -->
<div class="li-card" style="margin-top: 8px;">
  <div style="padding: 16px 24px; border-bottom: 1px solid rgba(0,0,0,0.08);">
    <h3 style="font-size: 18px; font-weight: 700; margin: 0;">More from ProConnect</h3>
  </div>
  <div id="related-posts" style="padding: 16px 24px;">
    <div class="text-center py-4" id="related-loading">
      <div class="spinner-border text-primary" role="status" style="width: 30px; height: 30px;">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
    <div id="related-posts-list"></div>
  </div>
</div>

<script>
  // Like button functionality
  const likeBtn = document.getElementById('likeBtn');
  if (likeBtn) {
    likeBtn.addEventListener('click', function() {
      const icon = this.querySelector('i');
      if (this.dataset.liked === '1') {
        this.dataset.liked = '0';
        this.style.color = '';
        icon.classList.replace('bi-hand-thumbs-up-fill', 'bi-hand-thumbs-up');
        if(this.lastChild) this.lastChild.textContent = ' Like';
      } else {
        this.dataset.liked = '1';
        this.style.color = '#0a66c2';
        icon.classList.replace('bi-hand-thumbs-up', 'bi-hand-thumbs-up-fill');
        if(this.lastChild) this.lastChild.textContent = ' Liked';
      }
    });
  }

  // Load related posts
  async function loadRelatedPosts() {
    try {
      const response = await fetch(`/api/blogs/feed?offset=0&limit=3`);
      const result = await response.json();
      
      if (result.success && result.data.length > 0) {
        const relatedContainer = document.getElementById('related-posts-list');
        relatedContainer.innerHTML = '';
        
        // Filter out current blog
        const currentSlug = '<%= blog.slug %>';
        const relatedBlogs = result.data.filter(b => b.slug !== currentSlug).slice(0, 3);
        
        if (relatedBlogs.length > 0) {
          relatedBlogs.forEach(blog => {
            const imageHtml = blog.blogImages && blog.blogImages.file_path
              ? `<img src="/public/storage/${blog.blogImages.file_path}" alt="${blog.title}" style="width: 100%; height: 120px; object-fit: cover; border-radius: 6px; margin-bottom: 8px;">`
              : '';
            
            const postHtml = `
              <div style="margin-bottom: 20px; cursor: pointer;" onclick="window.location.href='/blogs/${blog.slug}'">
                ${imageHtml}
                <h4 style="font-size: 14px; font-weight: 600; margin: 0 0 4px 0; color: rgba(0,0,0,0.9);">
                  ${blog.title}
                </h4>
                <p style="font-size: 12px; color: rgba(0,0,0,0.6); margin: 0;">
                  ${blog.author ? blog.author.name : 'ProConnect'} · ${new Date(blog.createdAt).toLocaleDateString()}
                </p>
              </div>
            `;
            relatedContainer.insertAdjacentHTML('beforeend', postHtml);
          });
        } else {
          relatedContainer.innerHTML = '<p class="text-muted text-center">No related posts found.</p>';
        }
        document.getElementById('related-loading').style.display = 'none';
      }
    } catch (error) {
      console.error('Error loading related posts:', error);
      document.getElementById('related-loading').style.display = 'none';
      document.getElementById('related-posts-list').innerHTML = '<p class="text-muted text-center">Unable to load related posts.</p>';
    }
  }

  // Load related posts on page load
  loadRelatedPosts();
</script>

<style>
  .post-action-btn[data-liked="1"] {
    color: #0a66c2;
  }
  .post-body-content p {
    margin-bottom: 1rem;
  }
  .post-body-content h1, .post-body-content h2, .post-body-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .post-body-content img {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
  }
</style>