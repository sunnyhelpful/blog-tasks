<%
  title = 'ProConnect - Professional Network';
%>

<!-- Compose -->
<div class="li-card">
  <div class="li-post-box">
    <div class="li-post-avatar">SR</div>
    <button class="li-post-input">Start a post, try writing an article</button>
  </div>
  <div class="li-post-actions">
    <a href="#" class="li-post-action video"><i class="bi bi-camera-video-fill"></i> Video</a>
    <a href="#" class="li-post-action photo"><i class="bi bi-image-fill"></i> Photo</a>
    <a href="#" class="li-post-action article"><i class="bi bi-pencil-square"></i> Write article</a>
  </div>
</div>

<!-- Dynamic Blog Posts Feed -->
<div id="blog-feed-container">
  <div class="text-center py-5" id="loading-spinner">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <div id="blog-posts"></div>
  <div class="text-center py-3" id="load-more-container" style="display: none;">
    <button class="btn btn-outline-primary" id="load-more-btn">Load More</button>
  </div>
</div>

<script>
  let currentOffset = 0;
  const limit = 5;
  let isLoading = false;
  let hasMore = true;

  function formatTimeAgo(date) {
    const now = new Date();
    const diffMs = now - new Date(date);
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);
    const diffWeeks = Math.floor(diffDays / 7);
    
    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    if (diffDays < 7) return `${diffDays}d ago`;
    return `${diffWeeks}w ago`;
  }

  function truncateText(text, maxLength = 300) {
    if (text.length <= maxLength) return text;
    return text.substring(0, maxLength) + '...';
  }

  function createPostCard(blog) {
    const imageHtml = blog.blogImages && blog.blogImages.file_path 
      ? `<div style="margin-top:10px;">
           <img src="/${blog.blogImages.file_path}" alt="${blog.title}" style="width:100%; max-height:400px; object-fit:cover;">
         </div>`
      : '';

    const timeAgo = formatTimeAgo(blog.createdAt);
    const author = blog.author;
    
    return `
      <div class="li-card" style="margin-top:8px;">
        <div class="post-header">
          <div class="post-author">
            <div class="post-logo" style="background:${author.gradient};border-radius:8px;font-size:12px;font-weight:800;">${author.initials}</div>
            <div>
              <div class="post-author-name">${author.name}</div>
              <div class="post-author-meta">${author.jobTitle} at ${author.company}</div>
              <div class="post-author-time"><span>${timeAgo}</span> <i class="bi bi-globe2" style="font-size:11px;"></i></div>
            </div>
          </div>
          <div class="post-controls">
            <button><i class="bi bi-three-dots"></i></button>
            <button><i class="bi bi-x-lg" style="font-size:16px;"></i></button>
          </div>
        </div>
        <div class="post-body">
          <h5 style="font-weight:700; margin-bottom:10px;">${blog.title}</h5>
          <p>${truncateText(blog.description)}</p>
          <a href="/blogs/${blog.slug}" style="color:#0a66c2; text-decoration:none; font-weight:500;">Read more →</a>
        </div>
        ${imageHtml}
        <div class="post-footer">
          <button class="post-action-btn" data-blog-id="${blog._id}"><i class="bi bi-hand-thumbs-up"></i> Like</button>
          <button class="post-action-btn"><i class="bi bi-chat"></i> Comment</button>
          <button class="post-action-btn"><i class="bi bi-repeat"></i> Repost</button>
          <button class="post-action-btn"><i class="bi bi-send"></i> Send</button>
        </div>
      </div>
    `;
  }

  async function loadBlogs() {
    if (isLoading || !hasMore) return;
    
    isLoading = true;
    document.getElementById('loading-spinner').style.display = 'block';
    
    try {
      const response = await fetch(`/api/blogs/feed?offset=${currentOffset}&limit=${limit}`);
      const result = await response.json();
      
      if (result.success && result.data.length > 0) {
        const postsContainer = document.getElementById('blog-posts');
        
        result.data.forEach(blog => {
          const postHtml = createPostCard(blog);
          postsContainer.insertAdjacentHTML('beforeend', postHtml);
        });
        
        currentOffset += result.data.length;
        hasMore = result.data.length === limit;
        
        if (hasMore) {
          document.getElementById('load-more-container').style.display = 'block';
        } else {
          document.getElementById('load-more-container').style.display = 'none';
        }
      } else {
        hasMore = false;
        document.getElementById('load-more-container').style.display = 'none';
        
        if (currentOffset === 0) {
          document.getElementById('blog-posts').innerHTML = `
            <div class="li-card text-center py-5">
              <p class="text-muted mb-0">No blogs found. Check back later!</p>
            </div>
          `;
        }
      }
    } catch (error) {
      console.error('Error loading blogs:', error);
      document.getElementById('blog-posts').innerHTML = `
        <div class="li-card text-center py-5">
          <p class="text-danger mb-0">Failed to load blogs. Please try again later.</p>
        </div>
      `;
    } finally {
      isLoading = false;
      document.getElementById('loading-spinner').style.display = 'none';
    }
  }

  // Load more button click handler
  document.getElementById('load-more-btn')?.addEventListener('click', loadBlogs);

  // Like button functionality
  document.addEventListener('click', function(e) {
    const likeBtn = e.target.closest('.post-action-btn');
    if (likeBtn && likeBtn.querySelector('.bi-hand-thumbs-up')) {
      const icon = likeBtn.querySelector('i');
      if (likeBtn.dataset.liked === '1') {
        likeBtn.dataset.liked = '0';
        likeBtn.style.color = '';
        icon.classList.replace('bi-hand-thumbs-up-fill', 'bi-hand-thumbs-up');
        if(likeBtn.lastChild) likeBtn.lastChild.textContent = ' Like';
      } else {
        likeBtn.dataset.liked = '1';
        likeBtn.style.color = '#0a66c2';
        icon.classList.replace('bi-hand-thumbs-up', 'bi-hand-thumbs-up-fill');
        if(likeBtn.lastChild) likeBtn.lastChild.textContent = ' Liked';
      }
    }
  });

  // Initial load
  loadBlogs();
</script>

<style>
  #loading-spinner {
    padding: 40px 0;
  }
  .post-body h5 {
    font-size: 16px;
    margin-bottom: 8px;
  }
  .post-body p {
    margin-bottom: 8px;
  }
</style>