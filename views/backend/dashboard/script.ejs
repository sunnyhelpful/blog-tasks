<script>
document.addEventListener("DOMContentLoaded", function () {
    fetch('/admin/dashboard', {
        headers: {
            'Accept': 'application/json'
        },
        cache: 'no-store'
    })
    .then(response => {
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
      return response.json();
    })
    .then(result => {
      if (result.status && result.data) {
        const mappings = [
          { id: 'systemUserCount', total: result.data.system_users, active: result.data.active_system_users },
          { id: 'platformUserCount', total: result.data.platform_users, active: result.data.active_platform_users },
          { id: 'brandCount', total: result.data.brands, active: result.data.active_brands },
          { id: 'categoryCount', total: result.data.categories, active: result.data.active_categories },
        ];

        mappings.forEach(({ id, total, active }) => {
          const $countElement = $('#' + id);
          const percentage = total > 0 ? Math.round((active / total) * 100) : 0;
          $countElement.attr('data-count', total || 0);
          $countElement.attr('data-percentage', percentage);
        });

        $('.count-up').each(function () {
          const $this = $(this);
          const targetCount = parseInt($this.attr('data-count')) || 0;
          const percentage = $this.attr('data-percentage') || 0;
          const duration = 2000;
          const interval = 20;
          const step = targetCount / (duration / interval);
          let currentCount = 0;

          const counter = setInterval(() => {
            currentCount += step;
            if (currentCount >= targetCount) {
              currentCount = targetCount;
              clearInterval(counter);
              
              const $activeText = $this.closest('.count-text').find('.active-text');
              if ($activeText.length) {
                $activeText.text(`+${percentage}%`);
              }
            }
            $this.text(Math.floor(currentCount));
          }, interval);
        });
      } else {
        console.warn("No data received.");
      }
    })
    .catch(err => {
        console.error("Error fetching dashboard data:", err);
    });

    /* $('.count-up').each(function () {
