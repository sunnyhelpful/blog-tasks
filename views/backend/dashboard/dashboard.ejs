<% title = trans.cruds.MODULE.DASHBOARD + ' - ' + companyInfo.NAME %>
<div class="container-fluid">
  <div class="page-title">
    <div class="row">
      <div class="col-sm-6 col-12"> 
        <h2>
          <%= trans.cruds.MODULE.DASHBOARD %>
        </h2>
        <div class="d-flex align-center">
            <h1><%= trans.global.hello %>, <%= userInfo.name || trans.global.not_available %>  
              <img src="/backend/images/dashboard-1/hand.png" width="20" alt=""/></h1>
          </div>
      </div>
      <div class="col-sm-6 col-12">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="<%= '/admin/dashboard' %>"><i class="iconly-Home icli svg-color"></i></a></li>
          <li class="breadcrumb-item"><%= trans.cruds.MODULE.DASHBOARD %></li>
          <li class="breadcrumb-item active"><%= trans.global.view %></li>
        </ol>
      </div>
    </div>
  </div>
</div>
<!-- Container-fluid starts-->

