                <div class="count-text">
                    <div class="count-sub-text count-up" id="platformUserCount" data-count="0">0</div>
                    <span class="active-text">0%</span>
                </div>
              </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              
              <div class="icon">
                  <svg class="stroke-icon">
                    <use href="/backend/svg/iconly-sprite.svg#Paper-plus"></use>
                  </svg>                                                   
              </div>
              <div class="title">
                <h4><%= trans.cruds.DASHBOARD.heading.BRAND %></h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="brandCount" data-count="0">0</div>
                    <span class="active-text">0%</span>
                </div>
              </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              
