        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xxl-6 col-xl-4 proorder-xxl-2 col-sm-6 box-col-6">
        <div class="card earning-card">
          <div class="card-header pb-0 card-no-border">
            <div class="header-top">
              <h3><%= trans.cruds.DASHBOARD.heading.earnings_trend %> </h3>
              <div class="dropdown">
                <button class="btn dropdown-toggle" id="userdropdown3" type="button" data-bs-toggle="dropdown" aria-expanded="false"><%= trans.messages.dashboard_fileration.monthly %></button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userdropdown3">
                  <a class="dropdown-item" href="javascript:;"><%= trans?.messages?.dashboard_fileration?.weekly %></a>
                  <a class="dropdown-item" href="javascript:;"><%= trans?.messages?.dashboard_fileration?.monthly %></a>
                  <a class="dropdown-item" href="javascript:;"><%= trans?.messages?.dashboard_fileration?.yearly %></a>
                </div>
              </div>
            </div>
          </div>
          <div class="card-body pb-0">
            <div class="d-flex align-center gap-3">
              <h2>SAR 4,875</h2>
                <span class="text-primary">
                  36.28%
                  <svg class="stroke-icon stroke-primary">
                    <use href="/backend/svg/icon-sprite.svg#arrow-down"></use>
                  </svg>
                </span>
            </div>
            <div id="earnings-chart"></div>
          </div>
        </div>
      </div>

      <div class="col-xxl-6 col-xl-6 proorder-xxl-7 col-lg-12 box-col-12">
        <div class="card job-card">
          <div class="card-header pb-0 card-no-border">
            <div class="header-top">
              <h3><%= trans.cruds.DASHBOARD.heading.recent_orders %></h3>
              <div>
                <%
                  var today = new Date();
                  var weekday = today.toLocaleDateString(lang, { weekday: 'long' });
                  var day = today.getDate();
                  var monthYear = today.toLocaleDateString(lang, { month: 'short', year: 'numeric' });
                %>
                <p>
                  <%= weekday %> <%= day %>, <span><%= monthYear %></span>
                </p>
              </div>
            </div>
          </div>
          <div class="card-body pt-2">
            <ul class="d-flex align-center justify-content-start gap-3"> 
              <li>
                <div class="d-flex gap-2"> 
                  <div class="flex-shrink-0 bg-light-primary">
                    <svg class="stroke-icon">
                      <use href="/backend/svg/iconly-sprite.svg#Folder"></use>
                    </svg>
                  </div>
                  <div class="flex-grow-1"> 
                    <h3>40</h3>
                    <p><%= trans.cruds.DASHBOARD.heading.total_orders %></p>
                  </div>
                </div>
              </li>
              <li>
                <div class="d-flex gap-2"> 
                  <div class="flex-shrink-0 bg-light-secondary">
                    <svg class="stroke-icon">
                      <use href="/backend/svg/icon-sprite.svg#employees"></use>
                    </svg>
                  </div>
                  <div class="flex-grow-1"> 
                    <h3>30</h3>
                    <p><%= trans.cruds.DASHBOARD.heading.users %></p>
                  </div>
                </div>
              </li>
            </ul>
            <div class="table-responsive theme-scrollbar">
              <table class="table display" style="width:100%">
                <thead>
                  <tr> 
                    <th># </th>
                    <th><%= trans.cruds.DASHBOARD.fields.title %> </th>
                    <th><%= trans.cruds.DASHBOARD.fields.seller %> </th>
                    <th><%= trans.cruds.DASHBOARD.fields.buyer %></th>
                    <th class="text-center"><%= trans.cruds.DASHBOARD.fields.createdAt %> </th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>1</td>
                    <td>Order #1023</td>
                    <td>Ahmed Tech</td>
                    <td>Sarah Ali</td>
                    <td class="text-center">2025-06-01 14:23</td>
                  </tr>
                  <tr>
                    <td>2</td>
                    <td>Service Request #2045</td>
                    <td>Global Solutions</td>
                    <td>Omar Khaled</td>
                    <td class="text-center">2025-06-03 09:15</td>
                  </tr>
                  <tr>
                    <td>3</td>
                    <td>Invoice #878</td>
                    <td>Yasmin Corp</td>
                    <td>Mohammed Nasser</td>
                    <td class="text-center">2025-06-05 17:42</td>
                  </tr>
                </tbody>

              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    
  </div>
<% } else { %>
  <div class="container-fluid">
    <div class="row w-100 h-100 justify-content-center align-items-center">
      <div class="col-md-8 col-lg-6">
        <div class="card border border-danger shadow-lg">
          <div class="card-body text-center p-5">
            
            <!-- Icon with circle background -->
            <div class="mb-4">
              <div class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle fs-2 icon-circle">
                <i class="fas fa-ban"></i>
              </div>
            </div>
  
            <!-- Message -->
            <h3 class="text-danger mb-3">
              <%= trans.messages.access_denied_title %>
            </h3>
            <p class="text-muted mb-4">
              🚫 <strong><%= trans.messages.access_denied_message %></strong><br>
              <%= trans.messages.access_denied_contact %>
            </p>
            
  
            <!-- CTA -->
            <!-- <a href="/admin" class="btn btn-outline-danger">
              <i class="fas fa-arrow-left"></i> Return to Home
            </a> -->
  
          </div>
        </div>
      </div>
    </div>
  </div>   
<% } %>
<!-- include dashboard script -->
<%- include('./script') %>