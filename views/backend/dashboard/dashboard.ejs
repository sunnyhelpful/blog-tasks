<% title = 'Blog Dashboard' %>
<div class="container-fluid">
  <div class="page-title">
    <div class="row">
      <div class="col-sm-6 col-12"> 
        <h2>Blog Dashboard</h2>
        <div class="d-flex align-center">
            <h1><img src="/backend/images/dashboard-1/hand.png" width="20" alt=""/></h1>
        </div>
      </div>
      <div class="col-sm-6 col-12">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/admin/dashboard"><i class="iconly-Home icli svg-color"></i></a></li>
          <li class="breadcrumb-item">Blog</li>
          <li class="breadcrumb-item active">View</li>
        </ol>
      </div>
    </div>
  </div>
</div>

<% if(userInfo.permissions.includes('access_dashboard')){ %>
  <div class="container-fluid blog-dashboard">

    <!-- Blog stats -->
    <div class="row">

      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              <div class="icon">📝</div>
              <div class="title">
                <h4>Total Posts</h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="postCount" data-count="0">0</div>
                </div>
              </div>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              <div class="icon">👤</div>
              <div class="title">
                <h4>Authors</h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="authorCount" data-count="0">0</div>
                </div>
              </div>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              <div class="icon">📂</div>
              <div class="title">
                <h4>Categories</h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="categoryCount" data-count="0">0</div>
                </div>
              </div>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              <div class="icon">🕒</div>
              <div class="title">
                <h4>Recent Posts</h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="recentPostCount" data-count="0">0</div>
                </div>
              </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Recent Posts Table -->
    <!-- <div class="row mt-4">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3>Recent Posts</h3>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              
            </div>
          </div>
        </div>
      </div>
    </div> -->

  </div>
<% } else { %>
  <div class="container-fluid">
    <div class="row w-100 h-100 justify-content-center align-items-center">
      <div class="col-md-8 col-lg-6">
        <div class="card border border-danger shadow-lg">
          <div class="card-body text-center p-5">
            <h3 class="text-danger mb-3">Access Denied</h3>
            <p class="text-muted mb-4">
              🚫 <strong>You do not have permission</strong><br>
              Please contact admin
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>