                  </svg>                                                         
              </div>
              <div class="title">
                <h4><%= trans.cruds.DASHBOARD.heading.SYSTEM_USERS %></h4>
                <div class="count-text">
                    <div class="count-sub-text count-up" id="systemUserCount" data-count="0">0</div>
                    <span class="active-text">0%</span>
                </div>
              </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card dashboard-card">
          <div class="card-body text-center">
              
              <div class="icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.0686 7.09091C16.0686 8.17589 15.6401 9.21642 14.8773 9.98362C14.1145 10.7508 13.0799 11.1818 12.0012 11.1818C10.9225 11.1818 9.88792 10.7508 9.12514 9.98362C8.36236 9.21642 7.93383 8.17589 7.93383 7.09091C7.93383 6.00593 8.36236 4.96539 9.12514 4.1982C9.88792 3.43101 10.9225 3 12.0012 3C13.0799 3 14.1145 3.43101 14.8773 4.1982C15.6401 4.96539 16.0686 6.00593 16.0686 7.09091ZM19.9733 19.3735C20.1522 20.2604 19.4071 21 18.509 21H5.49341C4.59371 21 3.85019 20.2604 4.0259 19.3735C4.40018 17.524 5.39846 15.8614 6.8517 14.6673C8.30494 13.4732 10.1238 12.8209 12.0004 12.8209C13.877 12.8209 15.6958 13.4732 17.1491 14.6673C18.6023 15.8614 19.6006 17.524 19.9749 19.3735" fill="#04196C"/>
