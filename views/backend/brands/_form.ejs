<div class="card-body">
  <div class="row">
    <!-- English brand Name Input -->
    <div class="col-sm-6 col-md-6">
      <div class="form-group mb-3">
        <label class="form-label" for="brand_en">
          <%= trans.cruds.BRAND.fields.title_en %> <span class="text-danger">*</span>
        </label>
        <input
          class="form-control"
          type="text"
          id="brand_en"
          name="title_en"
          value="<%= brand?.title?.en || '' %>"
          placeholder="<%= trans.global.enter_your %> <%= trans.cruds.BRAND.fields.title_en %>"
        />
      </div>
    </div>

    <!-- Arabic brand Name Input -->
    <div class="col-sm-6 col-md-6">
      <div class="form-group mb-3">
        <label class="form-label" for="brand_ar">
          <%= trans.cruds.BRAND.fields.title_ar %> <span class="text-danger">*</span>
        </label>
        <input
          class="form-control"
          type="text"
          id="brand_ar"
          name="title_ar"
          value="<%= brand?.title?.ar || '' %>"
          placeholder="<%= trans.global.enter_your %> <%= trans.cruds.BRAND.fields.title_ar %>"
        />
      </div>
    </div>

    <!-- Brand Image Input -->
    <div class="col-sm-6 col-md-6">
      <div class="d-flex gap-5">
        <div class="flex-grow-1">
            <div class="form-group mb-3">
            <label class="form-label" for="brand_image">
                <%= trans.cruds.BRAND.fields.brand_image || "Brand Image" %>
            </label>
            <input
                class="form-control"
                id="brand_image"
                type="file"
                name="brand_image"
                accept="image/jpeg, image/jpg, image/png, image/gif"
                onchange="previewImage(this, 'brand_image_preview')"
            />
            </div>
        </div>
        <img 
            class="img-100" 
            id="brand_image_preview" 
            alt="Brand Image" 
            src="<%= brand.brand_image?.file_path ? '/' + brand.brand_image.file_path.replace('public/', '') : '/backend/images/dummy-image.jpg' %>"/>
      </div>
    </div>
  
    <!-- Brand Icon Input -->
    <div class="col-sm-6 col-md-6">
      <div class="d-flex gap-5">
      <div class="flex-grow-1">
          <div class="form-group mb-3">
          <label class="form-label" for="brand_icon">
              <%= trans.cruds.BRAND.fields.brand_icon || "Brand Icon" %>
          </label>
          <input
              class="form-control"
              id="brand_icon"
              type="file"
              name="brand_icon"
              accept="image/jpeg, image/jpg, image/png, image/gif"
              onchange="previewImage(this, 'brand_icon_preview')"
          />
          </div>
      </div>
      <img 
          class="img-100" 
          id="brand_icon_preview" 
          alt="Brand Icon" 
          src="<%= brand.brand_icon?.file_path ? '/' + brand.brand_icon.file_path.replace('public/', '') : '/backend/images/dummy-image.jpg' %>"/>
      </div>
    </div>

    <!-- Description (English) -->
    <div class="col-md-12">
      <div class="form-group mb-3">
        <label class="form-label" for="description_en">
          <%= trans.cruds.BRAND.fields.description_en %>
        </label>
        <textarea
          class="form-control"
          name="description_en"
          id="description_en"
          rows="3"
        ><%= brand?.description?.en || '' %></textarea>
      </div>
    </div>

    <!-- Description (Arabic) -->
    <div class="col-md-12">
      <div class="form-group mb-3">
        <label class="form-label" for="description_ar">
          <%= trans.cruds.BRAND.fields.description_ar %>
        </label>
        <textarea
          class="form-control"
          name="description_ar"
          id="description_ar"
          rows="3"
        ><%= brand?.description?.ar || '' %></textarea>
      </div>
    </div>
  </div>
</div>
