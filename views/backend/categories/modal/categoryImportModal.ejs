<!-- Import Category Modal -->
<div class="modal fade common_modal" id="ImportCategoryModal" tabindex="-1" aria-labelledby="ImportCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary border-bottom-0">
                <h4 class="modal-title" id="ImportCategoryModalLabel">
                    <i class="bi bi-upload me-2"></i><%= trans.cruds.CATEGORY.heading.import_category || 'import_category' %>
                </h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" title="Close"></button>
            </div>

            <div class="modal-body modal-tab px-4 py-3">
                <ul class="nav nav-tabs" id="categoryTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="import-category-tab"
                            data-bs-toggle="tab" data-bs-target="#import-category-tab-pane"
                            type="button" role="tab" aria-controls="import-category-tab-pane" aria-selected="true">
                            <i class="bi bi-cloud-arrow-up me-1"></i><%= trans.cruds.CATEGORY.heading.import_category || 'import_category' %>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="download-category-sample-tab"
                            data-bs-toggle="tab" data-bs-target="#download-category-sample-tab-pane"
                            type="button" role="tab" aria-controls="download-category-sample-tab-pane" aria-selected="false">
                            <i class="bi bi-download me-1"></i><%= trans.cruds.CATEGORY.heading.download_sample || 'download_sample' %>
                        </button>
                    </li>
                </ul>

                <div class="tab-content mt-4" id="categoryTabContent">
                    <!-- Import Tab -->
                    <div class="tab-pane fade show active" id="import-category-tab-pane" role="tabpanel" aria-labelledby="import-category-tab">
                        <form id="importCategoryForm" enctype="multipart/form-data" method="POST" action="/admin/categories/imports" novalidate>
                            <div class="mb-3">
                                <label for="categoryFile" class="form-label fw-semibold">
                                    <%= trans.global.choose_file %>
                                    <i class="fas fa-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Accepted formats: .xlsx, .xls, .csv"></i>
                                </label>
                                <input type="file" id="categoryFile" name="category_file" class="form-control" accept=".xlsx,.xls,.csv" required aria-describedby="categoryFileHelp">
                                <div id="categoryFileHelp" class="form-text">
                                    <%= trans.global.accepted_formats %><span class="fw-semibold">.xlsx, .xls, .csv</span>
                                </div>
                            </div>
                            <div id="importCategoryFeedback" class="mb-3"></div>
                            <button type="submit" class="btn btn-success w-100 submitBtn">
                                <i class="bi bi-upload me-1"></i><%= trans.global.upload +' '+ trans.cruds.CATEGORY.title_singular %>
                            </button>
                        </form>
                    </div>

                    <!-- Download Sample Tab -->
                    <div class="tab-pane fade" id="download-category-sample-tab-pane" role="tabpanel" aria-labelledby="download-category-sample-tab">
                        <p>
                            <%= t(trans.messages.download_sample_file, { attribute: trans.cruds.CATEGORY.fields.category }) %>
                            <i class="fas fa-info-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Use this template to avoid import errors."></i>
                        </p>
                        <a href="/sample-files/sample-category.xlsx" class="btn btn-success w-100" download="sample-category.xlsx">
                            <i class="bi bi-download me-1"></i>
                            <%= trans.global.download_sample ||'download_sample' %>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>