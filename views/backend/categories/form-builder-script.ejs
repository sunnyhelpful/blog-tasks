                                break;

                            case "number":
                                formHTMLEN += `
                                    <label class="form-label text-left label_en" for="${id}_number_en">${label.en || ''}</label>
                                    <input type="number" class="form-control" id="${id}_number_en" name="${id}_en" placeholder="${placeholder.en || ''}">
