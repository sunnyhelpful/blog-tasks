const removedItemsMap = new Map();
const pageSize = 10;
let currentPage = 1;
let searchQuery = '';
let isLoading = false;
let hasMoreData = true;
let isInitialLoad = true;
const isEditMode = `<%= mode === "edit" ? true : false %>`;
const savedAttributes = JSON.parse(`<%- savedAttributes || "[]" %>`);
function initializeSavedAttributes() {
    if (!isEditMode || savedAttributes.length === 0) return;

    savedAttributes.sort((a, b) => (a.position || 0) - (b.position || 0));

    savedAttributes.forEach((attr, index) => {
        const position = attr.position || (index + 1);
        
        const $newItem = $(`
            <li class="drag-item" data-id="${attr.id}" data-type="${attr.type}" 
                data-value="${attr.title}" data-position="${position}" style="display: none;">
                ${attr.title}
                <span class="searchable-checkbox" title="Searchable">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="checkbox" 
                            ${attr.searchable ? 'checked' : ''}>
                    </div>
                </span>
                <span class="close-icon">&times;</span>
            </li>
        `);
        
        $("#darkDataBox").append($newItem);
        $newItem.fadeIn(200);
        
        removedItemsMap.set(attr.id, { 
            index: -1, 
            html: `<li class="drag-item title-${attr.id}" 
                draggable="true" 
                data-id="${attr.id}" 
                data-type="${attr.type}">
                ${attr.title}
            </li>`
        });
    });

    if (savedAttributes.length > 0) {
        $(".preview-darg-btn button, .save-btn button").prop("disabled", false);
    }
}

function maybeLoadMore() {
    const attrCount = $("#attrType .drag-item").length;
    const $attrList = $(".attribute-list");

    if ((attrCount < pageSize || $attrList[0].scrollHeight <= $attrList.innerHeight()) && hasMoreData) {
        loadAttributes();
    }
}

function loadAttributes() {
    if (isLoading || !hasMoreData) return;

    const $loader = $('.data-loader');
    if (isInitialLoad) {
        $loader.removeClass('d-none');
    }

    isLoading = true;

    const params = {
        start: (currentPage - 1) * pageSize,
        length: pageSize,
        search: { value: searchQuery },
        order: [{ column: 1, dir: 'desc' }],
        columns: [
            { data: 'title' },
            { data: 'createdAt' }
        ]
    };

    $.ajax({
        url: `/admin/attributes?${$.param(params)}&status=active`,
        type: 'GET',
        success: function (res) {
            $loader.addClass('d-none');
            isInitialLoad = false;
            if (res && res.data && res.data.length > 0) {
                res.data.forEach(item => {
                    const isInRemovedMap = removedItemsMap.has(item.id);
                    const isInDarkBox = $("#darkDataBox li").filter(function () {
                        return $(this).data("id") == item.id;
                    }).length > 0;

                    if (!isInRemovedMap && !isInDarkBox) {
                        $('#attrType').append(`
                            <li class="drag-item title-${item.id}" 
                                draggable="true" 
                                data-id="${item.id}" 
                                data-type="${item.type}">
                                ${item.title}
                            </li>
                        `);
                    }
                });
                currentPage++;
                isLoading = false;
                hasMoreData = true;
            } else {
                if (currentPage === 1) {
                    $('#attrType').append(`<li class="text-center">
                        <%= trans.global.language.zeroRecords %>
                    </li>`);
                }
                hasMoreData = false;
            }

            isLoading = false;
            setTimeout(() => maybeLoadMore(), 100);
        },
        error: function (xhr, status, error) {
            console.error('Error loading attributes:', error);
            $loader.addClass('d-none');
            isInitialLoad = false;
            isLoading = false;
        }
    });
}

function updatePositions() {
    $("#darkDataBox li").each(function (index) {
        const newPosition = index + 1;
        $(this).attr("data-position", newPosition);
    });
}

$(function () {
    // Initialize saved attributes
    initializeSavedAttributes();

    $("#darkDataBox").sortable({
        placeholder: "ui-state-highlight",
        update: function () {
            updatePositions();
        }
    });

    $('.perview-toggle-btn').on('click', function () {
        $(".perview-form").addClass('opendrawer');
        $("body").addClass('opendrawer-main');
    });

    $('.close-drawer').on('click', function () {
        $(".perview-form").removeClass('opendrawer');
        $("body").removeClass('opendrawer-main');
    });

    $(document).on('click', function (e) {
        const $target = $(e.target);
        if (
            !$target.closest('.perview-form').length &&
            !$target.closest('.perview-toggle-btn').length
        ) {
            $(".perview-form").removeClass('opendrawer');
            $("body").removeClass('opendrawer-main');
        }
    });

    $(document).on("dragstart", "#attrType .drag-item", function (e) {
        const text = $(this).text().trim();
        const id = $(this).data("id");
        const type = $(this).data("type");
        const payload = JSON.stringify({ text, id, type });

        e.originalEvent.dataTransfer.setData("application/json", payload);
    });

    $(document).on("dragover", "#darkDataBox", function (e) {
        e.preventDefault();
    });

    $(document).on("drop", "#darkDataBox", function (e) {
        e.preventDefault();
        const payload = e.originalEvent.dataTransfer.getData("application/json");
        const { text, id, type } = JSON.parse(payload);

        const exists = $("#darkDataBox li").filter(function () {
            return $(this).data("id") === id;
        }).length > 0;

        if (!exists) {
            const $original = $(`#attrType .drag-item[data-id="${id}"]`);
            const originalIndex = $original.index();

            removedItemsMap.set(id, { index: originalIndex, html: $original.prop('outerHTML') });
            $original.remove();

            const $newItem = $(`
                <li class="drag-item" data-id="${id}" data-type="${type}" data-value="${text}" style="display: none;">
                    ${text}
                    <span class="searchable-checkbox" title="Searchable">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="checkbox" id="searchablecheckbox">
                        </div>
                    </span>
                    <span class="close-icon">&times;</span>
                </li>
            `);
            $("#darkDataBox").append($newItem);
            $newItem.fadeIn(200, function () {
                this.scrollIntoView({ behavior: "smooth", block: "nearest" });
            });

            $(".preview-darg-btn button, .save-btn button").prop("disabled", false);
            updatePositions();
            maybeLoadMore();
        }
    });

    $(document).on("click", ".close-icon", function () {
        const $li = $(this).closest("li");
        const id = $li.data("id");

        if (removedItemsMap.has(id)) {
            const { index, html } = removedItemsMap.get(id);
            removedItemsMap.delete(id);

            const $items = $('#attrType .drag-item');
            if ($items.length === 0 || index >= $items.length) {
                $('#attrType').append(html);
            } else {
                $items.eq(index).before(html);
            }
        }

        $li.remove();

        if ($("#darkDataBox li").length === 0) {
            $(".preview-darg-btn button, .save-btn button").prop("disabled", true);
        }

        updatePositions();
        maybeLoadMore();
    });

    $(".attribute-list").on('scroll', function () {
        if ($(this).scrollTop() + $(this).innerHeight() >= this.scrollHeight) {
            loadAttributes();
        }
    });

    $('#searchInput').on('input', function (event) {
        clearTimeout(window.searchDebounce);
        const newSearchQuery = event.target.value.trim();
        window.searchDebounce = setTimeout(() => {
            if (newSearchQuery !== searchQuery) {
                currentPage = 1;
                hasMoreData = true;
                $('#attrType').empty();
                searchQuery = newSearchQuery;
                if (searchQuery.length > 0) {
                    $('.drawer-container').addClass('right-drawer');
                } else {
                    $('.drawer-container').removeClass('right-drawer');
                }
                loadAttributes();
            }
        }, 300);
    });

    // Initialize attribute loading
    loadAttributes();
});

