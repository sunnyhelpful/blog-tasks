            toolbar: "mytoolbar",
            toolbar_mytoolbar: "{bold,italic}|{fontname,fontsize}|{forecolor,backcolor}|removeformat"
            + "#{undo,redo,fullscreenenter,fullscreenexit,togglemore}"
        };

        if (document.querySelector('.description_editor')) {
            editorEn = new RichTextEditor(".description_editor", editor1cfg);
        }

        if (document.querySelector('.description_editor1')) {
            editorAr = new RichTextEditor(".description_editor1", editor1cfg);
        }
    }

    /* Preview Btn */
    $(document).on('click', '.perview-toggle-btn', function (e) {
        const selectedIds = $("#darkDataBox li").map(function () {
            return $(this).data("id");
        }).get();

        const orderedList = $("#darkDataBox li").map(function () {
            return {
                id: $(this).data("id"),
                text: $(this).data("value"),
                type: $(this).data("type"),
                position: $(this).data("position"),
            };
        }).get();

        $.ajax({
            url: `/admin/categories/form-buidler/fetch-selected-attributes`,
            type: 'GET',
            data: { ids: selectedIds },
            dataType: 'json',
            success: function (response) {
                if(response.status){
                    const attributes = response.data.attributes;
                    const sortedAttributes = orderedList.map(orderedItem => 
                        attributes.find(attr => attr._id === orderedItem.id)
                    )
                    .filter(attr => attr !== undefined)
                    .sort((a, b) => a.position - b.position);

                    $('.form-container').html('');
                    
                    let formHTMLEN = '';
                    let formHTMLAR = '';
                
                    sortedAttributes.forEach(attr => {
                        const title = attr.title || {};
                        const description = attr.description || {};
                        const label = attr.label || {};
                        const placeholder = attr.placeholder || {};
                        const options = attr.options || [];
                        const type = attr.type || '';
                        const id = attr._id;

                        formHTMLEN += `<div class="form-group" data-type="${type}" data-id="en-${attr._id}">`;
                        formHTMLAR += `<div class="form-group" data-type="${type}" data-id="ar-${attr._id}">`;
                        
                        switch (type) {
                            case "text":
                                formHTMLEN += `
                                    <label class="form-label text-left label_en" for="${id}_text_en">${label.en || ''}</label>
                                    <input type="text" class="form-control" id="${id}_text_en" name="${id}_en" placeholder="${placeholder.en || ''}">
