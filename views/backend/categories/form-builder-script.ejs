    $(document).on('click', '.saveSelectedFormBuilder', function (e) {
        e.preventDefault();
        
        const selectedItems = $('ul.darkdata-box[data-div-position="right-side"] li').map(function(index) {
            const $li = $(this);
            const id = $li.data("id");
            const isSearchable = $li.find('.form-check-input[type="checkbox"]').is(':checked');
            const position = index+1;

            return {
                id: id,
                searchable: isSearchable,
                position: position
            };
        }).get();
        const categoryId = $(document).find("#formbuilderCategoryId").val();
        
        const url = `/admin/categories/form-buidler-attribute/${categoryId}/store`;
        $.ajax({
            url: url,
            type: 'POST',
            data: { items: selectedItems },
            success: function (response) {
                if(response.status){
                    if(response?.data?.action == 'Create'){
                        const newTitle = `<%= trans.global.edit %>`;
                        document.querySelector('.breadcrumb-item.active.li-title').textContent = newTitle;
                    }
                    console.log(response?.data?.action);
                    
                    showNotificationPopup(response.message, 'success');
                } else {
                    const message = response.message || `<%= t(trans.messages.oops_something_went_wrong, {
                        attribute: trans.cruds.CATEGORY.form_builder.title_singular,
                    }) %>`;
                    showNotificationPopup(message, 'error');
                }
            }, 
            error: function(xhr, status, error){
                const response = xhr.responseJSON || {};
                const message = response.message || `<%= t(trans.messages.oops_something_went_wrong, {
                    attribute: trans.cruds.CATEGORY.form_builder.title_singular,
                }) %>`;
                showNotificationPopup(message, 'error');
            }
        });
    });
});

  // Image upload handler
function ImgUpload() {
    let imgArray = [];

    $('.upload__inputfile').each(function () {
        $(this).on('change', function (e) {
            const imgWrap = $(this).closest('.upload__box').find('.upload__img-wrap');
            const maxLength = parseInt($(this).attr('data-max_length'), 10);

            const files = Array.prototype.slice.call(e.target.files);
            files.forEach(function (f) {
                if (!f.type.match('image.*')) return;

                if (imgArray.length >= maxLength) return;

                imgArray.push(f);

                const reader = new FileReader();
                reader.onload = function (e) {
                    const html = `
                    <div class='upload__img-box'>
                        <div style='background-image: url(${e.target.result})' data-number='${$(".upload__img-close").length}' data-file='${f.name}' class='img-bg'>
                        <div class='upload__img-close'></div>
                        </div>
                    </div>`;
                    imgWrap.append(html);
                };
                reader.readAsDataURL(f);
            });
        });
    });

    // Remove uploaded image
    $('body').on('click', ".upload__img-close", function () {
        const file = $(this).parent().data("file");
        imgArray = imgArray.filter(f => f.name !== file);
        $(this).parent().parent().remove();
    });
}
