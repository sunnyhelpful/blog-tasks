    /* Form Validate For Save & Update */
    $("#categoryData").validate({
        rules: {
            category_type: {
                required: $("categoryModal").find('.categories-type-div').hasClass("d-none") ? false : true,
            },
            category_en: {
                required: true,
                minlength: 1
            },
            category_ar: {
                required: true,
                minlength: 1
            },
            attribute: {
                required: false,
            },
        },
        messages: {
            category_type:{
                required:`<%= t(trans.validation.client_side_validate.select_required_message, {
                    attribute: trans.cruds.CATEGORY_TYPE.title_singular,
                }) %>`,
            },
            category_en: {
                required: `<%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.cruds.CATEGORY.fields.category_en
                }) %>`,
                minlength: `<%= t(trans.validation.client_side_validate.min_length, {
                    attribute: trans.cruds.CATEGORY.fields.category_en,
                    min: 1
                }) %>`,
            },
            category_ar: {
                required: `<%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.cruds.CATEGORY.fields.category_ar
                }) %>`,
                minlength: `<%= t(trans.validation.client_side_validate.min_length, {
                    attribute: trans.cruds.CATEGORY.fields.category_ar,
                    min: 1
                }) %>`,
            },
            attribute:{
                required:`<%= t(trans.validation.client_side_validate.select_required_message, {
                    attribute: trans.cruds.ATTRIBUTE.title_singular,
                }) %>`,
            }
        },
        errorElement: 'span',
        errorPlacement: function(error, element) {
            error.addClass('invalid-feedback');
            if (element.attr("name") === "category_type") {
                error.insertAfter(element.next());
            } else if (element.attr("name") === "attribute") {
                error.insertAfter(element.next());
            } else {
                error.insertAfter(element);
            }
        },
        highlight: function(element) {
            $(element).addClass('is-invalid');
        },
        unhighlight: function(element) {
            $(element).removeClass('is-invalid');
        },
        submitHandler: function(form) {
            $(".page-loader").removeClass('d-none');
            const formData = new FormData(form);
            const url = $(form).attr("action");
            $.ajax({
                url: url,
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    $(".page-loader").addClass('d-none');
                    if (response.status) {
                        $('#categoryModal').modal('hide');

                        showNotificationPopup(response.message, 'success');
                        const data = response.data;
                        if (data?.storeCategory || data?.updatedCategory) {
                            const category = data.storeCategory ?? data.updatedCategory;
                            if(category.category_type !== 'category_type'){
                                if(category.parentId){
                                    const type = data.storeCategory ? 'create' : 'edit';
                                    appendCategoryAfterAddOrEdit(category, type);
                                } else {
                                    currentPage = 1;
                                    loadCategories();
                                }
                            }
                        }
                    } else {
                        showNotificationPopup(response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    $(".invalid-feedback").remove();
                    $(".page-loader").addClass('d-none');

                    const errors = xhr.responseJSON && xhr.responseJSON.error ? xhr.responseJSON.error : {};
                    const message = xhr.responseJSON && xhr?.responseJSON?.message ? xhr?.responseJSON?.message : '';

                    if (errors && Object.keys(errors).length > 0) {
                        displayErrorMessage(errors);
                    } else if (message) {
                        showNotificationPopup(message, 'error');
                    } else {
                        showNotificationPopup(`<%= t(trans.messages.oops_something_went_wrong, {
                            attribute: trans.cruds.MODULE.CATEGORY,
                        }) %>`, 'error');
                    }
                }
            });
        }
    });


    function displayErrorMessage(errors) {
        for (const field in errors) {
            let fieldElement = $(`input[name="${field}"], select[name="${field}"], textarea[name="${field}"]`);
            const fieldError = errors[field];
            const errorSpan = $("<span>").addClass("error invalid-feedback").text(fieldError);
            if(field == 'parent_category') {
                fieldElement.next().addClass('is-invalid').after(errorSpan);
            } else {
                fieldElement.after(errorSpan);
            }
            fieldElement.addClass('is-invalid');
        }
    }

    function initCategoryTypeSelect() {
        $('#category_type').select2({
            placeholder: `<%= trans.messages.please_select %>`,
            allowClear: true,
            dropdownParent: $('#categoryModal .modal-content'),
            ajax: {
                url: '/admin/categories-type',
                dataType: 'json',
                delay: 250,
                data: function (params) {
                    return {
                        search: { value: params.term || '' },
                        start: ((params.page || 1) - 1) * pageSize,
                        length: pageSize,
                        sortColumn: 'createdAt',
                        sortOrder: 'DESC'
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;
                    const results = data?.data || [];
                    return {
                        results: results.map(attr => ({
                            id: attr.id,
                            text: attr.title
                        })),
                        pagination: {
                            more: results.length === pageSize
                        }
                    };
                },
                cache: true
            },
            minimumInputLength: 0
        });
    }

    let oldSelectedVal = {};    
    function initAttributeSelect() {
        $('#attribute').select2({
            placeholder: `<%= trans.messages.please_select %>`,
            allowClear: true,
            dropdownParent: $('#categoryModal .modal-content'),
            ajax: {
                url: '/admin/attributes',
                dataType: 'json',
                delay: 250,
                data: function (params) {
                    return {
                        search: { value: params.term || '' },
                        start: ((params.page || 1) - 1) * pageSize,
                        length: pageSize,
                        sortColumn: 'createdAt',
                        sortOrder: 'DESC'
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;
                    const results = data?.data || [];
                    return {
                        results: results.map(attr => ({
                            id: attr.id,
                            text: attr.title
                        })),
                        pagination: {
                            more: results.length === pageSize
                        }
                    };
                },
                cache: true
            },
            minimumInputLength: 0
        });
    }

    /* Add Sub Category */
    $(document).on('click', '#btnAddCategory', function(e) {
        e.preventDefault();
        // let $this = $(this);
        // const url = $this.attr("href");

        $(".invalid-feedback").remove();
        $("#categoryData")[0].reset();
        $(".modal-title").html(`<%= trans.global.add + ' ' + trans.cruds.CATEGORY.title_singular %>`);
        $("#categoryData").data("action", "create");
        $("#categoryData").attr("action", "/admin/category/store");

        $(".form-control").removeClass("is-invalid");

        $("#category_image_preview")
            .attr("src", "/backend/images/dummy-image.jpg")
            .removeClass("img-100")
            .addClass("img-70");

        $("#category_icon_preview")
            .attr("src", "/backend/images/dummy-image.jpg")
            .removeClass("img-100")
            .addClass("img-70");
        
        $('.categories-type-div').removeClass('d-none');
        $('#category_type').empty().trigger('change');
        initCategoryTypeSelect();

        $('input[name="parent_category"]').remove();
        
        $('#attribute').empty().trigger('change');
        initAttributeSelect();

        var modal = new bootstrap.Modal(document.getElementById('categoryModal'));
        modal.show();
    });

    $(document).on('click', '#addSubCategory', function(e) {
        e.preventDefault();

        let $this = $(this);

        $(".invalid-feedback").remove();
        $("#categoryData")[0].reset();
        $(".modal-title").html(`<%= trans.global.add + ' ' + trans.cruds.CATEGORY.fields.sub_category %>`);
        $("#categoryData").data("action", "create");
        $("#categoryData").attr("action", "/admin/category/store");

        $(".form-control").removeClass("is-invalid");

        $("#category_image_preview")
            .attr("src", "/backend/images/dummy-image.jpg")
            .removeClass("img-100")
            .addClass("img-70");

        $("#category_icon_preview")
            .attr("src", "/backend/images/dummy-image.jpg")
            .removeClass("img-100")
            .addClass("img-70");

        $('input[name="parent_category"]').remove();

        $("<input>")
            .attr({
                type: "hidden",
                name: "parent_category",
                id: "parent_category",
                value: $this.data("id")
            })
            .appendTo("#categoryData");
        
        $('.categories-type-div').addClass('d-none');
        $('#category_type').empty().trigger('change');

        $('#attribute').empty().trigger('change');
        initAttributeSelect();
        
        /* if (editorEn && typeof editorEn.setHTMLCode === 'function') {
            editorEn.setHTMLCode('');
        }

        if (editorAr && typeof editorAr.setHTMLCode === 'function') {
            editorAr.setHTMLCode('');
        } */

        var modal = new bootstrap.Modal(document.getElementById('categoryModal'));
        modal.show();
    });

    $(document).on('click', '#editCategory', function(e) {
        e.preventDefault();
        let categoryId = $(this).data('id');
        if(categoryId){
            $(".page-loader").removeClass('d-none');
            const url = `/admin/category/${categoryId}/edit`
            $.ajax({
                url: url,
                success: function(response) {
                    $(".page-loader").addClass('d-none');
                    if (response.status) {
                        const data = response.data.data;
                        const category = data.category;
                        if(category.category_type !== 'category_type'){
                            const categoryType = category.category_type_info;

                            oldSelectedVal = category.attributeId;

                            $('#attribute').empty();
                            if (oldSelectedVal && Array.isArray(oldSelectedVal)) {
                                oldSelectedVal.forEach(attr => {
                                    const option = new Option(attr.title, attr.id, true, true);
                                    $('#attribute').append(option).trigger('change');
                                });
                            }
                            initAttributeSelect();

                            if(categoryType){
                                const option = new Option(categoryType.title, categoryType._id, true, true);
                                $('#category_type').append(option).trigger('change');
                                $('.categories-type-div').removeClass('d-none');
                            } else {
                                $('.categories-type-div').addClass('d-none');
                            }
                            initCategoryTypeSelect();
                            
                            $(".invalid-feedback").remove();
                            $("#categoryData")[0].reset();
                            $(".modal-title").html(`<%= trans.global.edit + ' ' + trans.cruds.CATEGORY.title_singular %>`);
                            $("#categoryData").data("action", "edit");
                            $("#categoryData").attr("action", `/admin/category/${categoryId}`);
                            $(".form-control").removeClass("is-invalid");

                            $("#category_image_preview")
                                .attr("src", category.category_image?.file_path ? `/${category.category_image.file_path}` : "/backend/images/dummy-image.jpg")
                                .removeClass("img-100")
                                .addClass("img-70");

                            $("#category_icon_preview")
                                .attr("src", category.category_icon?.file_path ? `/${category.category_icon.file_path}` : "/backend/images/dummy-image.jpg")
                                .removeClass("img-100")
                                .addClass("img-70");

                            $('input[name="parent_category"]').remove();

                            if(category.parentId){
                                $("<input>").attr({
                                    type: "hidden",
                                    name: "parent_category",
                                    id: "parent_category",
                                    value: category.parentId
                                }).appendTo("#categoryData");
                            }

                            $("#category_en").val(category.title?.en);
                            $("#category_ar").val(category.title?.ar);

                            $("#description_en").val(category.description?.en);
                            $("#description_ar").val(category.description?.ar);

                            /* if (editorEn && typeof editorEn.setHTMLCode === 'function') {
                                editorEn.setHTMLCode(category.description.en || '');
                            }
                            if (editorAr && typeof editorAr.setHTMLCode === 'function') {
                                editorAr.setHTMLCode(category.description.en || '');
                            } */

                            var modal = new bootstrap.Modal(document.getElementById('categoryModal'));
                            modal.show();
                        }
                    } else {
                        showNotificationPopup(response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    showNotificationPopup(`<%= t(trans.messages.oops_something_went_wrong, {
                        attribute: trans.cruds.MODULE.CATEGORY,
                    }) %>`, 'error');
                }
            });
        } else {
            showNotificationPopup(`<%= t(trans.messages.not_found, {
                attribute: trans.cruds.CATEGORY.title_singular
            }) %>`, 'error');
        }
    });

    $(document).on("click", ".deleteCategory", function(e) {
        e.preventDefault();
        let $this = $(this);
        const id = $this.data('id');
        if (id) {
            Swal.fire({
                title: `<%= trans.messages.sweetalert.delete.title %>`,
                text: `<%= trans.messages.sweetalert.delete.message %>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: `<%= trans.messages.sweetalert.confirm_button_text %>`,
                cancelButtonText: `<%= trans.messages.sweetalert.cancel_button_text %>`,
                reverseButtons: true,
                allowOutsideClick: false,
            }).then((result) => {
                if (result.isConfirmed) {
                    $(".page-loader").removeClass('d-none');
                    $.ajax({
                        url: $this.data('url'),
                        type: 'DELETE',
                        dataType: 'json',
                        success: function(response) {
                            $(".page-loader").addClass('d-none');
                            if (response.status) {
                                const deletedLi = $(`.category-list-${id}`);
                                const parentUl = deletedLi.closest('ul');
                                const isTopLevel = deletedLi.parent('.categoriesList').length > 0;
                                if (isTopLevel) {
                                    loadCategories();
                                } else {
                                    deletedLi.remove();
                                    
                                    if (parentUl && parentUl.children('li').length === 0) {
                                        const parentLi = parentUl.closest('li.branch');
                                        parentUl.remove();
                                        
                                        if (parentLi.length) {
                                            parentLi.removeClass('branch');
                                            parentLi.find('> .indicator').remove();
                                        }
                                    }
                                    
                                    filteredRecords--;
                                    totalRecords--;
                                    updatePaginationInfo();
                                }
                                
                                showNotificationPopup(response.message, 'success', null);
                            } else {
                                showNotificationPopup(response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            $(".page-loader").addClass('d-none');
                            showNotificationPopup(`<%= t(trans.messages.oops_something_went_wrong, {
                                attribute: trans.cruds.MODULE.CATEGORY,
                            }) %>`, 'error');
                        }
                    });
                }
            });
        } else {
            showNotificationPopup(`<%= t(trans.messages.not_found, {
                attribute: trans.cruds.CATEGORY.title_singular
            }) %>`, 'error');
        }
    });

    function updatePaginationInfo() {
        const startEntry = (currentPage - 1) * pageSize + 1;
        const endEntry = Math.min(currentPage * pageSize, filteredRecords);
        document.getElementById('paginationInfo').textContent = 
            `<%= trans.global.language.showing %> ${startEntry} <%= trans.global.language.to %> ${endEntry} <%= trans.global.language.of %> ${filteredRecords} <%= trans.global.language.entries %>`;

        const totalPages = Math.ceil(filteredRecords / pageSize);
        if (totalPages < currentPage) {
            currentPage = totalPages > 0 ? totalPages : 1;
            loadCategories();
        } else {
            renderPaginationControls();
        }
    }

    function appendCategoryAfterAddOrEdit(category, type = "create") {
        const currentLang = `<%= lang %>`;
        let statusClass = 'bg-secondary';
        let statusText = 'Unknown';

        switch (category.status) {
            case 'active':
                statusClass = 'bg-success';
                statusText = 'Active';
                break;
            case 'inactive':
                statusClass = 'bg-danger';
                statusText = 'Inactive';
                break;
        }

        let verificationClass = 'bg-secondary';
        let verificationText = 'Unknown';

        switch (category.isVerification) {
            case 'approved':
                verificationClass = 'bg-success';
                verificationText = 'Approved';
                break;
            case 'pending':
                verificationClass = 'bg-warning text-dark';
                verificationText = 'Pending';
                break;
            case 'rejected':
                verificationClass = 'bg-danger';
                verificationText = 'Rejected';
                break;
        }

        let innerHtml = `
            <span class="title-${category.id}">${category.title?.[currentLang]}</span>
            <div class="box-outer">
                <div>
                    <div class="d-flex gap-1">
                        <div class="bages-outer">
                            ${
                                userInfo.permissions.includes('category_status')
                                    ? `<div class="category-status cursor-pointer" data-id="${category.id}" data-status="${category.status}">
                                            <span class="badge ${statusClass}">${statusText}</span>
                                    </div>`
                                    : `<div><span class="badge ${statusClass}">${statusText}</span></div>`
                            }
                            ${
                                userInfo.permissions.includes('category_verification')
                                    ? `<div class="category-verification cursor-pointer" data-id="${category.id}" data-status="${category.isVerification}">
                                            <span class="badge ${verificationClass}">${verificationText}</span>
                                    </div>`
                                    : `<div><span class="badge ${verificationClass}">${verificationText}</span></div>`
                            }
                        </div>
                        ${
                            userInfo.permissions.includes('create_category')
                                ? `<a href="javascript:;" class="btn btn-sm btn-success btn-create categoryUser" id="addSubCategory" data-id="${category.id}">
                                    <i class="fas fa-plus"></i>
                                </a>`
                                : ``
                        }
                        ${
                            userInfo.permissions.includes('edit_category')
                                ? `<a href="#" class="btn btn-sm btn-primary btn-edit categoryUser" id="editCategory" data-id="${category.id}">
                                    <i class="fas fa-edit"></i>
                                </a>`
                                : ``
                        }
                        ${
                            userInfo.permissions.includes('view_category')
                                ? `<a href="/admin/category/${category.id}" class="btn btn-sm btn-info btn-view categoryUser" data-id="${category.id}">
                                    <i class="fas fa-eye"></i>
                                </a>`
                                : ``
                        }
                        ${
                            userInfo.permissions.includes('delete_category')
                                ? `<a href="javascript:;" class="btn btn-sm btn-danger btn-delete deleteCategory" data-id="${category.id}" data-url="/admin/category/${category.id}/delete">
                                    <i class="fas fa-trash"></i>
                                </a>`
                                : ``
                        }
                    </div>
                </div>
            </div>`;

        let existingCategory = $(`.category-list-${category.id}`);
        if (type === "edit" && existingCategory.length) {
            const newTitle = category.title?.[currentLang] || '';
            $(`.title-${category.id}`).text(newTitle);
            return;
        } else {
            let fullHtml = `<li class="category-list-${category.id}">${innerHtml}</li>`;

            if (!category.parentId) {
                const currentCount = $('.categoriesList > li').length;
                if (currentCount >= pageSize) {
                    loadCategories();
                    return;
                }
                
                $('.categoriesList').prepend(fullHtml);
            } else {
                let parentElement = $(`.category-list-${category.parentId}`);
                if (!parentElement.length) {
                    loadCategories();
                    return;
                }

                if (!parentElement.hasClass('branch')) {
                    parentElement.addClass('branch');
                    parentElement.prepend(`<i class="indicator glyphicon fas fa-plus"></i>`);
                    
                    initTreeForElement(parentElement);
                }

                let sublist = parentElement.children('ul');
                if (!sublist.length) {
                    sublist = $('<ul style="display: none;"></ul>');
                    parentElement.append(sublist);
                }

                sublist.append(fullHtml);
            }

            if (category.children && category.children.length > 0) {
                $(`.category-list-${category.id}`).addClass('branch')
                    .prepend(`<i class="indicator glyphicon fas fa-plus"></i>`)
                    .append('<ul style="display: none;"></ul>');
                
                initTreeForElement($(`.category-list-${category.id}`));
            }
        }
    }

    function initTreeForElement(element) {
        element.find('> .indicator').removeClass('fa-minus').addClass('fa-plus');
        
        element.off('click').on('click', function(e) {
            if (this === e.target || $(e.target).hasClass('indicator')) {
                var icon = $(this).children('i.indicator:first');
                icon.toggleClass('fa-plus fa-minus');
                $(this).children('ul').slideToggle();
            }
        });

        element.find('> .indicator').off('click').on('click', function(e) {
            $(this).closest('li').click();
            e.stopPropagation();
        });

        element.find('> a, > button').off('click').on('click', function(e) {
            $(this).closest('li').click();
            e.preventDefault();
            e.stopPropagation();
        });
    }

    /*  */
    $(document).on('click', '.category-status', function(e) {
        e.preventDefault();
        $(".page-loader").removeClass('d-none');

        const $this = $(this);
        const categoryId = $this.data('id');
        const currentStatus = $this.data('status');
        const newStatus = currentStatus === 'active' ? 'inactive' : 'active';
        const url = `/admin/categories/status-update/${categoryId}`;
        $.ajax({
            url: url,
            type: 'POST',
            data: { status: newStatus },
            success: function(response) {
                $(".page-loader").addClass('d-none');
                if (response.status) {
                    $this.data('status', newStatus);
                    const badge = $this.find('span.badge');
                    badge.text(newStatus.charAt(0).toUpperCase() + newStatus.slice(1));
                    if (newStatus === 'active') {
                        badge.removeClass('bg-danger bg-secondary').addClass('bg-success');
                    } else {
                        badge.removeClass('bg-success bg-secondary').addClass('bg-danger');
                    }
                    showNotificationPopup(response.message, 'success');
                } else {
                    showNotificationPopup(response.message, 'error');
                }
            },
            error: function(xhr, status, error) {
                $(".page-loader").addClass('d-none');
                console.error('Error updating status:', error);
                showNotificationPopup(`<%= t(trans.messages.oops_something_went_wrong, {
                    attribute: trans.cruds.MODULE.CATEGORY,
                }) %>`, 'error');
            }
        });
    });


    $(document).on('click', '.category-verification', function(e) {
        e.preventDefault();
        $(".page-loader").removeClass('d-none');
        const $this = $(this);
        const categoryId = $this.data('id');
        const currentStatus = $this.data('status');
        let newStatus;

        switch (currentStatus) {
            case 'pending':
                newStatus = 'approved';
                break;
            case 'approved':
                newStatus = 'rejected';
                break;
            case 'rejected':
                newStatus = 'approved';
                break;
            default:
                newStatus = 'pending';
        }
        const url = `/admin/categories/verify-update/${categoryId}`;
        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ isVerification: newStatus }),
            success: function(response) {
                $(".page-loader").addClass('d-none');
                if (response.status) {
                    $this.data('status', newStatus);
                    const badge = $this.find('span.badge');
                    badge.text(newStatus.charAt(0).toUpperCase() + newStatus.slice(1));
                    badge.removeClass('bg-success bg-danger bg-warning text-dark');

                    switch (newStatus) {
                        case 'approved':
                            badge.addClass('bg-success');
                            break;
                        case 'pending':
                            badge.addClass('bg-warning text-dark');
                            break;
                        case 'rejected':
                            badge.addClass('bg-danger');
                            break;
                    }
                    showNotificationPopup(response.message, 'success');
                } else {
                    showNotificationPopup(response.message, 'error');
                }
            },
            error: function(xhr, status, error) {
                $(".page-loader").addClass('d-none');
                console.error('Error updating verification status:', error);
                showNotificationPopup(`<%= t(trans.messages.oops_something_went_wrong, {
                    attribute: trans.cruds.MODULE.CATEGORY,
                }) %>`, 'error');
            }
        });
    });

    /* Excel Import */
    $(document).on('click', '#btnImportCategory', function(e){
        e.preventDefault();
        $("#importCategoryForm")[0].reset();
        $(".form-control").removeClass("is-invalid");
        $(".error").remove();
        $("#ImportCategoryModal").modal('show');
    });

    $("#importCategoryForm").validate({
        rules: {
            category_file: {
                required: true,
                fileExtension: ["xls", "xlsx", "csv"],
            },
        },
        messages: {
            category_file: {
                required: `<%= t(trans.validation.client_side_validate.select_required_message, {
                    attribute: trans.cruds.CATEGORY.fields.category_file
                }) %>`,
                fileExtension: `<%= trans.validation.client_side_validate.invalid_file_selected +' .xls, .xlsx, .csv' %>`,
            },
        },
        errorElement: 'span',
        errorPlacement: function(error, element) {
            error.addClass('invalid-feedback');
            error.insertAfter(element);
        },
        highlight: function(element) {
            $(element).addClass('is-invalid');
        },
        unhighlight: function(element) {
            $(element).removeClass('is-invalid');
        },
        submitHandler: function(form, event) {
            event.preventDefault();
            $(document).find('.submitBtn').prop('disabled', true);
            var formData = new FormData(form);
            const url = $(form).attr('action');
            $(".page-loader").removeClass('d-none');
            $.ajax({
                url: url,
                type: "POST",
                timeout: 300000,
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    $(".page-loader").addClass('d-none');
                    $(document).find('.submitBtn').prop('disabled', false);
                    if (response.status) {
                        loadCategories();
                        showNotificationPopup(response.message, 'success');
                        $("#ImportCategoryModal").modal('hide');
                    } else {
                        showNotificationPopup(response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    $(".page-loader").addClass('d-none');
                    $(document).find('.submitBtn').prop('disabled', false);
                    const response = xhr?.responseJSON || {};
                    const errorMessage = `<%= t(trans.messages.oops_something_went_wrong, {
                        attribute: trans.cruds.MODULE.CATEGORY,
                    }) %>`;
                    if(response){
                        showNotificationPopup(response.message || errorMessage, 'error');
                    }
                }
            });
        }
    });

    $.validator.addMethod("fileExtension", function(value, element, param) {
        if (this.optional(element)) {
            return true;
        }
        var ext = value.split('.').pop().toLowerCase();
        return $.inArray(ext, param) !== -1;
    }, `<%= trans.validation.client_side_validate.file_extension_required +' '+ '.xls, .xlsx, .csv' %>`);
});
</script>
