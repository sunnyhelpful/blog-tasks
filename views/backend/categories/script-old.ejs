    $.fn.extend({
        treed: function (o) {
            var openedClass = 'fas fa-minus';
            var closedClass = 'fas fa-plus';

            if (typeof o != 'undefined') {
                if (typeof o.openedClass != 'undefined') openedClass = o.openedClass;
                if (typeof o.closedClass != 'undefined') closedClass = o.closedClass;
            }

            var tree = $(this);
            tree.addClass("tree1");

            tree.find('li').has("ul").each(function () {
                var branch = $(this);
                branch.prepend("<i class='indicator glyphicon " + closedClass + "'></i>");
                branch.addClass('branch');

                branch.children('ul').hide();

                branch.on('click', function (e) {
                    if (this === e.target || $(e.target).hasClass('indicator')) {
                        var icon = $(this).children('i.indicator:first');
                        icon.toggleClass(openedClass + " " + closedClass);
                        $(this).children('ul').slideToggle();
                    }
                });
            });

            tree.find('.branch .indicator').each(function () {
                $(this).on('click', function (e) {
                    $(this).closest('li').click();
                    e.stopPropagation();
                });
            });

            tree.find('.branch>a, .branch>button').each(function () {
                $(this).on('click', function (e) {
                    $(this).closest('li').click();
                    e.preventDefault();
                    e.stopPropagation();
                });
            });
        }
    });

    loadCategories();

    document.getElementById('searchInput')?.addEventListener('input', function (event) {
        searchQuery = event.target.value.trim();
        currentPage = 1;
        loadCategories();
    });

    window.goToPage = function (page) {
        currentPage = page;
        loadCategories();
    }

    function loadCategories() {
        const queryParams = new URLSearchParams({
            start: (currentPage - 1) * pageSize,
            length: pageSize,
            search: searchQuery,
            sortColumn: 'createdAt',
            sortOrder: 'DESC'
        }).toString();

        fetch(`/admin/categories?${queryParams}`, {
            headers: { 'Accept': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            allNestedCategories = data.data || [];
            totalRecords = data.recordsTotal || 0;
            filteredRecords = data.recordsFiltered || 0;

            if (allNestedCategories.length > 0) {
                paginateCategories();
            } else {
                document.querySelector('.categoriesList').innerHTML = `<li class="text-center">
                    <%= trans.global.language.zeroRecords %>
                </li>`;
                document.getElementById('paginationInfo').textContent = '';
                document.getElementById('paginationControls').innerHTML = '';
            }
        })
        .catch(err => console.error('Error loading categories:', err));
    }

    function paginateCategories() {
        const startEntry = (currentPage - 1) * pageSize + 1;
        const endEntry = Math.min(currentPage * pageSize, filteredRecords);

        document.getElementById('paginationInfo').textContent = 
            `<%= trans.global.language.showing %> ${startEntry} <%= trans.global.language.to %> ${endEntry} <%= trans.global.language.of %> ${filteredRecords} <%= trans.global.language.entries %>`;

        document.querySelector('.categoriesList').innerHTML = renderCategories(allNestedCategories);

        $('.categoriesList').treed({
            openedClass: 'fas fa-minus',
            closedClass: 'fas fa-plus'
        });

        renderPaginationControls();
    }

    function renderPaginationControls() {
        const totalPages = Math.ceil(filteredRecords / pageSize);
        let buttons = '';

        if (totalPages > 1) {
            if (currentPage > 1) {
                buttons += `<a href="javascript:void(0);" class="btn btn-pagination" onclick="goToPage(${currentPage - 1})"><%= trans.global.language.paginate.previous %></a>`;
            } else {
                buttons += `<a href="javascript:void(0);" class="btn btn-pagination disabled"><%= trans.global.language.paginate.previous %></a>`;
            }

            for (let i = 1; i <= totalPages; i++) {
                buttons += `<a href="javascript:void(0);" class="btn btn-pagination ${i === currentPage ? 'btn-active' : ''}" onclick="goToPage(${i})">${i}</a>`;
            }

            if (currentPage < totalPages) {
                buttons += `<a href="javascript:void(0);" class="btn btn-pagination" onclick="goToPage(${currentPage + 1})"><%= trans.global.language.paginate.next %></a>`;
            } else {
                buttons += `<a href="javascript:void(0);" class="btn btn-pagination disabled"><%= trans.global.language.paginate.next %></a>`;
            }
        }

        document.getElementById('paginationControls').innerHTML = buttons;
    }

    function renderCategories(categories) {
        let html = '';

        for (const category of categories) {
            let statusClass = 'bg-secondary';
            let statusText = 'Unknown';

            switch (category.status) {
                case 'active':
                    statusClass = 'bg-success';
                    statusText = 'Active';
                    break;
                case 'inactive':
                    statusClass = 'bg-danger';
                    statusText = 'Inactive';
                    break;
            }

            let verificationClass = 'bg-secondary';
            let verificationText = 'Unknown';

            switch (category.isVerification) {
                case 'approved':
                    verificationClass = 'bg-success';
                    verificationText = 'Approved';
                    break;
                case 'pending':
                    verificationClass = 'bg-warning text-dark';
                    verificationText = 'Pending';
                    break;
                case 'rejected':
                    verificationClass = 'bg-danger';
                    verificationText = 'Rejected';
                    break;
            }

            html += `
            <li class="category-list-${category.id}">
                <span class="title-${category.id}">${category.title}</span>
                <div class="box-outer">
                    <div>
                        <div class="d-flex gap-1">
                            <div class="bages-outer">
                                ${
                                    userInfo.permissions.includes('category_status')
                                        ? `<div class="category-status cursor-pointer" data-id="${category.id}" data-status="${category.status}">
                                                <span class="badge ${statusClass}">${statusText}</span>
                                        </div>`
                                        : `<div><span class="badge ${statusClass}">${statusText}</span></div>`
                                }
                                ${
                                    userInfo.permissions.includes('category_verification')
                                        ? `<div class="category-verification cursor-pointer" data-id="${category.id}" data-status="${category.isVerification}">
                                                <span class="badge ${verificationClass}">${verificationText}</span>
                                        </div>`
                                        : `<div><span class="badge ${verificationClass}">${verificationText}</span></div>`
                                }
                            </div>
                            ${
                                userInfo.permissions.includes('create_category')
                                ? `<a href="/admin/category/store" class="btn btn-sm btn-success btn-create categoryUser" id="addSubCategory" data-id="${category.id}">
                                    <i class="fas fa-plus"></i>
                                    </a>` 
                                : ``
                            }
                            ${
                                userInfo.permissions.includes('edit_category')
                                ? `<a href="/admin/category/${category.id}/edit" class="btn btn-sm btn-primary btn-edit categoryUser" id="editCategory" data-id="${category.id}">
                                    <i class="fas fa-edit"></i>
                                </a>` 
                                : ``
                            }
                            ${
                                userInfo.permissions.includes('view_category')
                                ? `<a href="/admin/category/${category.id}" class="btn btn-sm btn-info btn-view categoryUser" data-id="${category.id}">
                                    <i class="fas fa-eye"></i>
                                </a>` 
                                : ``
                            }
                            ${
                                userInfo.permissions.includes('delete_category')
                                ? `<a href="/admin/category/${category.id}/delete" class="btn btn-sm btn-danger btn-delete deleteCategory" data-id="${category.id}" data-url="/admin/category/${category.id}/delete">
                                    <i class="fas fa-trash"></i>
                                </a>` 
                                : ``
                            }
                        </div>
                    </div>
                </div>
            `;

            if (category.children && category.children.length > 0) {
                html += `<ul>${renderCategories(category.children, userInfo)}</ul>`;
            }

            html += `</li>`;
        }

        return html;
    }


    function badgeColor(status) {
        switch (status) {
            case 'approved': return 'success';
            case 'rejected': return 'danger';
            case 'pending': return 'warning';
            default: return 'secondary';
        }
    }

    function capitalize(str) {
        return str.charAt(0).toUpperCase() + str.slice(1);
    }

