<% title = trans.cruds.MODULE.SETTING + ' - ' + companyInfo.NAME %>
<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h2><%= trans.cruds.MODULE.SETTING %></h2>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="<%= '/admin/dashboard' %>"><i class="iconly-Home icli svg-color"></i> <%= trans.global.home %></a></li>
                    <li class="breadcrumb-item"><a href="<%= '/admin/settings' %>"><%= trans.cruds.MODULE.SETTING %></a></li>
                    <li class="breadcrumb-item active"><%= trans.global.list %></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header card-no-border d-flex justify-content-between align-items-center">
                    <div class="">
                        <h3><%= trans.cruds.SETTING.heading.setting_list || 'setting_list' %></h3>
                    </div>
                </div>
                <div class="card-body pt-0">
                    <div class="table-responsive theme-scrollbar">
                        <table class="table table-lg display settingsTable" style="width:100%">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th data-data="details"><%= trans.cruds.SETTING.fields.name %></th>
                                    <th data-data="status"><%= trans.cruds.SETTING.fields.status %></th>
                                    <th data-data="createdAt"><%= trans.cruds.SETTING.fields.createdAt %></th>
                                    <th data-data="action"><%= trans.cruds.SETTING.fields.action %></th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via AJAX -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('./script') %>