<div class="card-body">
    <div class="row">
        <!-- Name Input -->
        <div class="col-sm-6 col-md-6">
            <div class="form-group mb-3">
                <label class="form-label" for="name"><%= trans.cruds.ROLE.fields.title %> <span class="text-danger">*</span></label>
                <input class="form-control" type="text" id="name" name="name" 
                    value="<%= role.name || '' %>" placeholder="<%= trans.global.enter_your + ' ' + trans.cruds.ROLE.fields.title %>">
            </div>
        </div>
        <!-- Role Select -->
        <div class="col-sm-6 col-md-6">
            <div class="form-group mb-3">
              <label class="form-label" for="permissions"><%= trans.cruds.PERMISSION.title %> <span class="text-danger">*</span></label>
              <select class="select2 form-control" name="permissions[]" id="permissions" multiple="multiple">
                <% for (const module in groupedPermissions) { %>
                  <optgroup label="<%= module %>">
                    <% groupedPermissions[module].forEach(permission => { %>
                      <option value="<%= permission._id %>"
                        <%= assignedPermissions.includes(permission._id.toString()) ? 'selected' : '' %>>
                        <%= permission.title %>
                      </option>
                    <% }) %>
                  </optgroup>
                <% } %>
              </select>        
            </div>            
        </div>          
    </div>
    <hr>
</div>
