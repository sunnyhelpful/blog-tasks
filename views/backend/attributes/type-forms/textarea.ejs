<div class="selected-data mb-4 attribute-textarea-data" data-type="textarea" style="display: none;">
    <div class="row">
        <div class="col-12 col-md-7 textarea-form">
            <!-- Preview Button -->
            <div class="previwe-btn-box preview-list" data-type="textarea">
                <a href="javascript:;" class="btn btn-info btn-view perviewtextWithLabel" id="perviewtextWithLabel" title="<%= trans.global.preview %>">
                    <i class="fas fa-eye"></i>
                </a>
            </div>
            <div class="lang-card-box mb-3">
                <div class="title-box">
                    <h3 class="mt-0">
                        <%= trans.global.label %>
                    </h3>
                </div>
                <div class="lang-form-input-group">
                    <div class="row w-100">
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                            <input
                                class="form-control"
                                type="text"
                                name="label_en"
                                id="textarea_label_en"
                                value="<%= attribute?.label?.en || '' %>"
                                placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.english +')' %>"
                            />
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                            <input
                                class="form-control"
                                type="text"
                                name="label_ar"
                                id="textarea_label_ar"
                                value="<%= attribute?.label?.ar || '' %>"
                                placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.arabic +')' %>"
                            />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="lang-card-box mb-4">
                <div class="title-box">
                    <h3 class="mt-0">
                        <%= trans.global.placeholder %>
                    </h3>
                </div>
                <div class="lang-form-input-group">
                    <div class="row w-100">
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                                <input
                                    class="form-control"
                                    type="text"
                                    name="placeholder_en"
                                    id="textarea_placeholder_en"
                                    value="<%= attribute?.placeholder?.en || '' %>"
                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.placeholder +' ('+ trans.global.english +')' %>"
                                />
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                                <input
                                    class="form-control"
                                    type="text"
                                    name="placeholder_ar"
                                    id="textarea_placeholder_ar"
                                    value="<%= attribute?.placeholder?.ar || '' %>"
                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.placeholder +' ('+ trans.global.arabic +')' %>"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-5">
            <div class="preview-data preview-text-data" data-type="textarea" style="display: none;">
                <fieldset>
                    <legend><%= trans.global.preview %></legend>
                    <div class="mb-4">
                        <div class="lang-card-box">
                            <div class="lang-form-input-group">
                                <div class="row w-100">
                                    <div class="col-12 col-md-6">
                                        <div class="form-group">
                                            <div class="lang-title-box">
                                                <%= trans.global.english %>
                                            </div>
                                            
                                            <label class="form-label text-left label_en" for="textarea_value_attribute_en">
                                                
                                            </label>
                                            <textarea 
                                                class="form-control" 
                                                name="textarea_value_en" 
                                                id="textarea_value_attribute_en" 
                                                rows="5" 
                                                spellcheck="true"
                                                placeholder="">
                                            </textarea>             
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <div class="form-group">
                                            <div class="lang-title-box">
                                                <%= trans.global.arabic %>
                                            </div>
                                            
                                            <label class="form-label text-left label_ar" for="textarea_value_attribute_ar"></label>
                                            <textarea 
                                                class="form-control" 
                                                name="textarea_value_ar" 
                                                id="textarea_value_attribute_ar" 
                                                rows="5" 
                                                spellcheck="false"
                                                placeholder="">
                                            </textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
    </div>
</div>