<div class="radio-atr attribute-radio-data" data-type="radio">
    <div class="radio-options-wrapper selected-data mb-4" data-type="radio" style="display: none;">
        <div class="row">
            <div class="col-12 col-md-7 radio-clone-wrap radio-form">
                <div class="previwe-btn-box preview-list" data-type="radio">
                    <a href="javascript:;" class="btn btn-info btn-view perviewtextWithLabel" id="perviewtextWithLabel" title="<%= trans.global.preview %>">
                        <i class="fas fa-eye"></i>
                    </a>
                </div>

                <div class="lang-card-box mb-3">
                    <div class="title-box">
                        <h3 class="mt-0"><%= trans.global.label %></h3>
                    </div>
                    <div class="lang-form-input-group align-box-wrap" data-type="radio">
                        <div class="row w-100">
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text"
                                        name="label_en"
                                        id="radio_label_en"
                                        value="<%= attribute?.label?.en || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.english +')' %>"
                                    />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text" 
                                        name="label_ar" 
                                        id="radio_label_ar"
                                        value="<%= attribute?.label?.ar || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.arabic +')' %>"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (attribute && attribute.options && attribute.options.length > 0 && (attribute.type == 'radio')) { %>
                    <% attribute.options.forEach(function(option, index) {
                        const count = index + 1;
                        const isLast = index === attribute.options.length - 1;
                    %>
                        <div class="option-box mb-4" data-count="<%= count %>">
                            <div class="lang-card-box">
                                    <div class="title-box">
                                        <h3 class="mt-0"><%= trans.global.option + ' ' + count %></h3>
                                    </div>
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control" 
                                                    type="text" 
                                                    name="option_en[]" 
                                                    id="radio_option_en_<%= count %>" 
                                                    value="<%= option.value.en %>" 
                                                    placeholder="<%= trans.global.enter_your + ' ' + trans.global.option + ' (' + trans.global.english + ')' %>" 
                                                />
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control" 
                                                    type="text" 
                                                    name="option_ar[]" 
                                                    id="radio_option_ar_<%= count %>" 
                                                    value="<%= option.value.ar %>" 
                                                    placeholder="<%= trans.global.enter_your + ' ' + trans.global.option + ' (' + trans.global.arabic + ')' %>" 
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="action-group">
                                <% if (attribute.options.length > 1) { %>
                                    <button type="button" class="action-btn remove-btn btn btn-secondary" data-type="radio">−</button>
                                <% } %>
                                    <button type="button" class="action-btn add-btn btn btn-primary <%= isLast ? '' : 'hidebtn' %>" data-type="radio">＋</button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Default fallback if no options -->
                    <div class="option-box mb-4" data-count="1">
                        <div class="lang-card-box">
                            <div class="title-box">
                                <h3 class="mt-0"><%= trans.global.option + ' 1' %></h3>
                            </div>
                            <div class="lang-form-input-group">
                                <div class="row w-100">
                                    <div class="col-12 col-md-6">
                                        <div class="form-group">
                                            <input 
                                                class="form-control" 
                                                type="text" 
                                                name="option_en[]" 
                                                id="radio_option_en_1" 
                                                value="" 
                                                placeholder="<%= trans.global.enter_your + ' ' + trans.global.option + ' (' + trans.global.english + ')' %>" 
                                            />
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <div class="form-group">
                                            <input 
                                                class="form-control" 
                                                type="text" 
                                                name="option_ar[]" 
                                                id="radio_option_ar_1" 
                                                value="" 
                                                placeholder="<%= trans.global.enter_your + ' ' + trans.global.option + ' (' + trans.global.arabic + ')' %>" 
                                            />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="action-group">
                            <button type="button" class="action-btn add-btn btn btn-primary" data-type="radio">＋</button>
                        </div>
                    </div>
                <% } %>
            </div>

            <div class="col-12 col-md-5 position-relative">
                <div class="preview-data preview-text-data" data-type="radio" style="display: none;">
                    <fieldset>
                        <legend><%= trans.global.preview %></legend>
                        <div class="mb-4">
                            <div class="lang-card-box">
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.english %>
                                                </div>

                                                <!-- <h4 class="my-3">
                                                    How Old are you?
                                                </h4>

                                                <div class="form-check w-fit">
                                                    <input class="form-check-input" id="flexRadioDefault-age1" type="radio" name="flexRadioDefault-age">
                                                    <label class="form-check-label" for="flexRadioDefault-age1">Under 12</label>
                                                </div>
                                                <div class="form-check w-fit">
                                                    <input class="form-check-input" id="flexRadioDefault-age2" type="radio" name="flexRadioDefault-age" checked="">
                                                    <label class="form-check-label" for="flexRadioDefault-age2">Under 18</label>
                                                </div>
                                                <div class="form-check w-fit">
                                                    <input class="form-check-input" id="flexRadioDefault-age3" type="radio" name="flexRadioDefault-age" checked="">
                                                    <label class="form-check-label" for="flexRadioDefault-age3">Under 35</label>
                                                </div>
                                                <div class="form-check w-fit">
                                                    <input class="form-check-input" id="flexRadioDefault-age4" type="radio" name="flexRadioDefault-age" checked="">
