                                                </div> -->
                                                <h4 class="my-3 label-en-radio"></h4>
                                                <div class="options-en-radio"></div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.arabic %>
                                                </div>

                                                <div class="listing-ar-content">
                                                    <!-- <h4 class="my-3">
                                                        كم عمرك؟
                                                    </h4>

                                                    <div class="form-check w-fit">
                                                        <input class="form-check-input" id="flexRadioDefault-ar-1" type="radio" name="flexRadioDefault-ar">
                                                        <label class="form-check-label" for="flexRadioDefault-ar-1">أقل من 12 عامًا</label>
                                                    </div>
                                                    <div class="form-check w-fit">
                                                        <input class="form-check-input" id="flexRadioDefault-ar-2" type="radio" name="flexRadioDefault-ar" checked="">
                                                        <label class="form-check-label" for="flexRadioDefault-ar-2">أقل من 18 عامًا</label>
                                                    </div>
                                                    <div class="form-check w-fit">
                                                        <input class="form-check-input" id="flexRadioDefault-ar-3" type="radio" name="flexRadioDefault-ar" checked="">
                                                        <label class="form-check-label" for="flexRadioDefault-ar-3">أقل من 35 عامًا</label>
                                                    </div>
                                                    <div class="form-check w-fit">
                                                        <input class="form-check-input" id="flexRadioDefault-ar-4" type="radio" name="flexRadioDefault-ar" checked="">
                                                        <label class="form-check-label" for="flexRadioDefault-ar-4">فوق 35</label>
                                                    </div> -->
                                                    <h4 class="my-3 label-ar-radio"></h4>
                                                    <div class="options-ar-radio"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
</div>
