                                                    <div class="form-check w-fit main-img-checkbox">
                                                        <div class="img-checkbox">
                                                            <input class="main-img-cover form-check-input" id="img-check-4" type="checkbox">
                                                            <label class="form-check-label mb-0" for="img-check-4">
