                <% if (attribute && attribute.options && attribute.options.length > 0 && (attribute.type == 'checkboximagetitle')) { %>
                    <% attribute.options.forEach(function(option, index) { 
                        const count = index + 1;
                        const isLast = index === attribute.options.length - 1;
                        const meta = option?.meta || {};
                        const isCloned = meta.isCloned === true;
                        const title_en = option?.value?.en || '';
                        const title_ar = option?.value?.ar || '';
                    %>
                        <div class="clone-data-main" data-count="<%= count %>">
                            <div class="clone-data-inner">
                                <div class="lang-card-box">
                                    <div class="title-box">
                                        <h3 class="mt-0"><%= trans.global.option_title + ' ' + count %></h3>
                                    </div>
                                    <div class="lang-form-input-group">
                                        <div class="row w-100">
                                            <div class="col-12 col-md-6">
                                                <div class="form-group">
                                                    <input 
                                                        class="form-control" 
                                                        type="text" 
                                                        name="option_title_en[]" 
                                                        id="checkboximagetitle_option_title_en_<%= count %>"
                                                        value="<%= title_en %>"
                                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.option_title +' ('+ trans.global.english +')' %>"
                                                    >
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6">
                                                <div class="form-group">
                                                    <input 
                                                        class="form-control" 
                                                        type="text" 
                                                        name="option_title_ar[]" 
                                                        id="checkboximagetitle_option_title_ar_<%= count %>"
                                                        value="<%= title_ar %>"
                                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.option_title +' ('+ trans.global.arabic +')' %>"
                                                    >
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="lang-card-box">
                                    <div class="title-box">
                                        <h3 class="mt-0"><%= trans.global.option_image + ' ' + count %></h3>
                                    </div>
                                    <div class="lang-form-input-group">
                                        <div class="row w-100">
                                            <div class="col-12 col-md-6 check-image-size-checkboximagetitle">
                                                <div class="copy-file-upload-data" data-type="checkboximagetitle">
                                                    <div class="form-group">
                                                        <input 
                                                            class="form-control uploader-1" 
                                                            type="file" 
                                                            name="option_en[]" 
                                                            id="checkboximagetitle_option_image_en_<%= count %>" 
                                                            accept="image/jpeg, image/jpg, image/png, image/gif"
                                                            data-existing-image="/<%= meta?.fileUrl_en %>" data-existing-image-for-save="<%= meta?.fileUrl_en %>"
                                                        >
                                                    </div>
                                                    <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                        <input class="form-check-input primary" id="checkboximagetitle_imageclonecheck_<%= count %>" name="checkboximagetitle_imageclonecheck_<%= count %>" type="checkbox" data-type="checkboximagetitle" <%= isCloned ? 'checked' : '' %>>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6 hidecheckbox">
                                                <div class="form-group">
                                                    <input 
                                                        class="form-control uploader-2" 
                                                        type="file" 
                                                        name="option_ar[]" 
                                                        id="checkboximagetitle_option_image_ar_<%= count %>" 
                                                        accept="image/jpeg, image/jpg, image/png, image/gif"
                                                        data-existing-image="/<%= meta?.fileUrl_ar %>" data-existing-image-for-save="<%= meta?.fileUrl_ar %>"
                                                    >
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Action Group: Add/Remove -->
                            <div class="action-group">
                                <% if (attribute.options.length > 1) { %>
                                    <button type="button" class="btn btn-secondary remove-btn" data-type="checkboximagetitle">−</button>
                                <% } %>
                                <button type="button" class="btn btn-primary add-btn <%= isLast ? '' : 'hidebtn' %>" data-type="checkboximagetitle">＋</button>
                            </div>
                        </div>
                    <% }) %>

                <% } else { %>
                    <div class="clone-data-main" data-count="1">
                        <div class="clone-data-inner">
                            <div class="lang-card-box">
                                <div class="title-box">
                                    <h3 class="mt-0"><%= trans.global.option_title +' 1' %></h3>
                                </div>
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control" 
                                                    type="text" 
                                                    name="option_title_en[]" 
                                                    id="checkboximagetitle_option_title_en_1"
                                                    value="" 
                                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.option_title +' ('+ trans.global.english +')' %>"
                                                >
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control" 
                                                    type="text" 
                                                    name="option_title_ar[]" 
                                                    id="checkboximagetitle_option_title_ar_1"
                                                    value="" 
                                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.option_title +' ('+ trans.global.arabic +')' %>"
                                                >
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="lang-card-box">
                                <div class="title-box">
                                    <h3 class="mt-0"><%= trans.global.option_image +' 1' %></h3>
                                </div>
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6 check-image-size-checkboximagetitle">
                                            <div class="copy-file-upload-data" data-type="checkboximagetitle">
                                                <div class="form-group">
                                                    <input class="form-control uploader-1" type="file" name="option_en[]" id="checkboximagetitle_option_image_en_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                                </div>
                                                <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                    <input class="form-check-input primary" id="checkboximagetitle_imageclonecheck_1" name="checkboximagetitle_imageclonecheck_1" type="checkbox" data-type="checkboximagetitle" checked>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6 hidecheckbox">
                                            <div class="form-group">
                                                <input class="form-control uploader-2" type="file" name="option_ar[]" id="checkboximagetitle_option_image_ar_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="action-group">
                            <button type="button" class="btn btn-primary add-btn" data-type="checkboximagetitle">＋</button>
                        </div>
                    </div>
                <% } %>
            </div>
            <div class="col-12 col-md-5 position-relative">
                <div class="preview-data preview-text-data" data-type="checkboximagetitle" style="display: none;">
