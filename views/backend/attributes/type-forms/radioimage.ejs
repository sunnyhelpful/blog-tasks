<div class="radioimage-atr attribute-radioimage-data" data-type="radioimage">
    <div class="radioimage-options-wrapper selected-data mb-4" data-type="radioimage" style="display: none;">
        <div class="row">
            <div class="col-12 col-md-7 radioimage-clone-wrap radioimage-form">

                <div class="previwe-btn-box preview-list" data-type="radioimage">
                    <a href="javascript:;" class="btn btn-info btn-view perviewtextWithLabel" id="perviewtextWithLabel" title="<%= trans.global.preview %>">
                        <i class="fas fa-eye"></i>
                    </a>
                </div>

                <div class="lang-card-box mb-3">
                    <div class="title-box">
                        <h3 class="mt-0"><%= trans.global.label %></h3>
                    </div>
                    <div class="lang-form-input-group align-box-wrap" data-type="radioimage">
                        <div class="row w-100">
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text"
                                        name="label_en"
                                        id="radioimage_label_en"
                                        value="<%= attribute?.label?.en || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.english +')' %>"
                                    />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text" 
                                        name="label_ar" 
                                        id="radioimage_label_ar"
                                        value="<%= attribute?.label?.ar || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.arabic +')' %>"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (attribute && attribute.options && attribute.options.length > 0 && (attribute.type == 'radioimage')) { %>
                    <% attribute.options.forEach(function(option, index) {
                        const count = index + 1;
                        const meta = option.meta || {};
                        const isCloned = meta.isCloned === true;
                        const isLast = index === attribute.options.length - 1;
                    %>
                        <div class="option-box mb-4" data-count="<%= count %>">
                            <div class="lang-card-box">
                                <div class="title-box">
                                    <h3 class="mt-0"><%= trans.global.option + ' ' + count %></h3>
                                </div>
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6 check-image-size-radioimage">
                                            <div class="copy-file-upload-data" data-type="radioimage">
                                                <div class="form-group">
                                                    <input 
                                                        class="form-control uploader-1" 
                                                        type="file" 
                                                        name="option_en[]" 
                                                        id="radioimage_option_en_<%= count %>" 
                                                        data-existing-image="/<%= meta?.fileUrl_en %>" data-existing-image-for-save="<%= meta?.fileUrl_en %>"
                                                        accept="image/jpeg, image/jpg, image/png, image/gif" 
                                                    />
                                                </div>
                                                <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                    <input 
                                                        class="form-check-input primary" 
                                                        id="radioimage_imageclonecheck_<%= count %>" 
                                                        name="radioimage_imageclonecheck_<%= count %>" 
                                                        type="checkbox" 
                                                        data-type="radioimage" 
                                                        <%= isCloned ? 'checked' : '' %>
                                                    />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-md-6 hidecheckbox">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control uploader-2" 
                                                    type="file" 
                                                    name="option_ar[]" 
                                                    id="radioimage_option_ar_<%= count %>" 
                                                    data-existing-image="/<%= meta?.fileUrl_ar %>" data-existing-image-for-save="<%= meta?.fileUrl_ar %>"
                                                    accept="image/jpeg, image/jpg, image/png, image/gif"  
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="action-group">
                                <% if (attribute.options.length > 1) { %>
                                    <button type="button" class="action-btn remove-btn btn btn-secondary" data-type="radioimage">−</button>
                                <% } %>
                                    <button type="button" class="action-btn add-btn btn btn-primary <%= isLast ? '' : 'hidebtn' %>" data-type="radioimage">＋</button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="clone-data-main">
                        <div class="clone-data-inner">
                            <div class="option-box mb-4" data-count="1">
                                <div class="lang-card-box">
                                    <div class="title-box">
                                        <h3 class="mt-0"><%= trans.global.option +' 1' %></h3>
                                    </div>
                                    <div class="lang-form-input-group">
                                        <div class="row w-100">
                                            <div class="col-12 col-md-6 check-image-size-radioimage">
                                                <div class="copy-file-upload-data" data-type="radioimage">
                                                    <div class="form-group">
                                                        <input class="form-control uploader-1" type="file" name="option_en[]" id="radioimage_option_en_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                                        <!-- <input class="form-control formFileRadioImage" id="formFileRadioImage" type="file" name="option_en[]" accept="image/jpeg, image/jpg, image/png, image/gif"> -->
                                                    </div>
                                                    <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                        <input class="form-check-input primary" id="radioimage_imageclonecheck_1" name="radioimage_imageclonecheck_1" type="checkbox" data-type="radioimage" checked>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6 hidecheckbox">
                                                <div class="form-group">
                                                    <input class="form-control uploader-2" type="file" name="option_ar[]" id="radioimage_option_ar_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                                    <!-- <input class="form-control formFileRadioImage" id="formFile" type="file" name="option_ar[]" accept="image/jpeg, image/jpg, image/png, image/gif"> -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="action-group">
                                    <button type="button" class="btn btn-primary add-btn" data-type="radioimage">＋</button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

            </div>
            <div class="col-12 col-md-5 position-relative">
                <div class="preview-data preview-text-data" data-type="radioimage" style="display: none;">
                    <fieldset>
                        <legend><%= trans.global.preview %></legend>
                        <div class="mb-4">
                            <div class="lang-card-box">
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.english %>
                                                </div>

                                                <!-- <h4 class="my-3">Select Image</h4>

                                                <div class="form-check w-fit main-img-checkbox">
                                                    <div class="img-checkbox">
                                                        <input class="main-img-cover form-check-input" id="img-radio-4img" type="radio" name="radio6">
                                                        <label class="form-check-label mb-0" for="img-radio-4img">
                                                            <img class="img-100" id="imagePreview-option023" for="flexRadioDefault-age1-img" alt="" src="/backend/images/dummy-image.jpg">
                                                        </label>
                                                    </div>
                                                </div> -->
                                                <h4 class="my-3 label-en-radioimage"></h4>
                                                <div class="options-en-radioimage option-grid-view-en"></div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.arabic %>
                                                </div>
                                                <div class="listing-ar-content">
                                                    <!-- <h4 class="my-3">حدد الصورة</h4>
                                                    <div class="form-check w-fit main-img-checkbox">
                                                        <div class="img-checkbox">
                                                            <input class="main-img-cover form-check-input" id="img-radio-5img" type="radio" name="radio6">
                                                            <label class="form-check-label mb-0" for="img-radio-5img">
                                                                <img class="img-100" id="imagePreview-option-ar23" for="flexRadioDefault-age1-img" alt="" src="/backend/images/dummy-image.jpg">
                                                            </label>
                                                        </div>
                                                    </div> -->
                                                    <h4 class="my-3 label-ar-radioimage"></h4>
                                                    <div class="options-ar-radioimage option-grid-view-ar"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
</div>
