<div class="checkboximage-atr attribute-checkboximage-data" data-type="checkboximage">
    <div class="checkboximage-options-wrapper selected-data mb-4" data-type="checkboximage" style="display: none;">
        <div class="row">
            <div class="col-12 col-md-7 checkboximage-clone-wrap checkboximage-form">

                <div class="previwe-btn-box preview-list" data-type="checkboximage">
                    <a href="javascript:;" class="btn btn-info btn-view perviewtextWithLabel" id="perviewtextWithLabel" title="<%= trans.global.preview %>">
                        <i class="fas fa-eye"></i>
                    </a>
                </div>

                <div class="lang-card-box mb-3">
                    <div class="title-box">
                        <h3 class="mt-0"><%= trans.global.label %></h3>
                    </div>
                    <div class="lang-form-input-group align-box-wrap" data-type="checkboximage">
                        <div class="row w-100">
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text"
                                        name="label_en"
                                        id="checkboximage_label_en"
                                        value="<%= attribute?.label?.en || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.english +')' %>"
                                    />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input 
                                        class="form-control" 
                                        type="text" 
                                        name="label_ar"
                                        id="checkboximage_label_ar"
                                        value="<%= attribute?.label?.ar || '' %>"
                                        placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.arabic +')' %>"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (attribute && attribute.options && attribute.options.length > 0 && (attribute.type == 'checkboximage')) { %>
                    <% attribute.options.forEach(function(option, index) {
                        const count = index + 1;
                        const meta = option.meta || {};
                        const isCloned = meta.isCloned === true;
                        const isLast = index === attribute.options.length - 1;
                    %>
                    <div class="clone-data-main" data-count="<%= count %>">
                        <div class="clone-data-inner option-box mb-4">
                            <div class="lang-card-box">
                                <div class="title-box">
                                    <h3 class="mt-0"><%= trans.global.option + ' ' + count %></h3>
                                </div>
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6 check-image-size-checkboximage">
                                            <div class="copy-file-upload-data" data-type="checkboximage">
                                                <div class="form-group">
                                                    <input 
                                                        class="form-control uploader-1" 
                                                        type="file" 
                                                        name="option_en[]" 
                                                        id="checkboximage_option_image_en_<%= count %>" 
                                                        accept="image/jpeg, image/jpg, image/png, image/gif" 
                                                        data-existing-image="/<%= meta?.fileUrl_en %>" data-existing-image-for-save="<%= meta?.fileUrl_en %>"
                                                    >
                                                </div>
                                                <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                    <input 
                                                        class="form-check-input primary" 
                                                        id="checkboximage_imageclonecheck_<%= count %>" 
                                                        name="checkboximage_imageclonecheck_<%= count %>" 
                                                        type="checkbox" 
                                                        data-type="checkboximage" 
                                                        <%= isCloned ? 'checked' : '' %>
                                                    >
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6 hidecheckbox">
                                            <div class="form-group">
                                                <input 
                                                    class="form-control uploader-2" 
                                                    type="file" 
                                                    name="option_ar[]" 
                                                    id="checkboximage_option_image_ar_<%= count %>" 
                                                    accept="image/jpeg, image/jpg, image/png, image/gif"
                                                    data-existing-image="/<%= meta?.fileUrl_ar %>" data-existing-image-for-save="<%= meta?.fileUrl_ar %>"
                                                    <%= isCloned ? 'disabled' : '' %> 
                                                >
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="action-group">
                                <% if (attribute.options.length > 1) { %>
                                    <button type="button" class="btn btn-secondary remove-btn" data-type="checkboximage">−</button>
                                <% } %>
                                <button type="button" class="btn btn-primary add-btn <%= isLast ? '' : 'hidebtn' %>" data-type="checkboximage">＋</button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <div class="clone-data-main">
                        <div class="clone-data-inner">
                            <div class="option-box mb-4" data-count="1">
                                <div class="lang-card-box">
                                    <div class="title-box">
                                        <h3 class="mt-0"><%= trans.global.option +' 1' %></h3>
                                    </div>
                                    <div class="lang-form-input-group">
                                        <div class="row w-100">
                                            <div class="col-12 col-md-6 check-image-size-checkboximage">
                                                <div class="copy-file-upload-data" data-type="checkboximage">
                                                    <div class="form-group">
                                                        <input class="form-control uploader-1" type="file" name="option_en[]" id="checkboximage_option_image_en_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                                    </div>
                                                    <div class="copy-image-upload checkmark-box copy-btn" title="Same image for Arabic">
                                                        <input class="form-check-input primary" id="checkboximage_imageclonecheck_1" name="checkboximage_imageclonecheck_1" type="checkbox" data-type="checkboximage" checked>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6 hidecheckbox">
                                                <div class="form-group">
                                                    <input class="form-control uploader-2" type="file" name="option_ar[]" id="checkboximage_option_image_ar_1" accept="image/jpeg, image/jpg, image/png, image/gif">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="action-group">
                                    <button type="button" class="btn btn-primary add-btn" data-type="checkboximage">＋</button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

            </div>
            <div class="col-12 col-md-5 position-relative">
                <div class="preview-data preview-text-data" data-type="checkboximage" style="display: none;">
                    <fieldset>
                        <legend><%= trans.global.preview %></legend>
                        <div class="mb-4">
                            <div class="lang-card-box">
                                <div class="lang-form-input-group">
                                    <div class="row w-100">
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.english %>
                                                </div>
                                                <!-- <h4 class="my-3">
                                                    Select Image
                                                </h4>

                                                <div class="form-check w-fit main-img-checkbox">
                                                    <div class="img-checkbox">
                                                        <input class="main-img-cover form-check-input" id="img-check-1" type="checkbox">
                                                        <label class="form-check-label mb-0" for="img-check-1">
                                                            <img class="img-100" id="imagePreview-checkbox023" alt="" src="/backend/images/dummy-image.jpg">
                                                        </label>
                                                    </div>
                                                </div> -->
                                                <h4 class="my-3 label-en-checkboximage"></h4>
                                                <div class="options-en-checkboximage option-grid-view-en"></div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="form-group">
                                                <div class="lang-title-box">
                                                    <%= trans.global.arabic %>
                                                </div>
                                                <div class="listing-ar-content">
                                                    <!-- <h4 class="my-3">
                                                        حدد الصورة
                                                    </h4>
                                                    <div class="form-check w-fit main-img-checkbox">
                                                        <div class="img-checkbox">
                                                            <input class="main-img-cover form-check-input" id="img-check-2" type="checkbox">
                                                            <label class="form-check-label mb-0" for="img-check-2">
                                                                <img class="img-100" id="imagePreview-checkbox-ar23" alt="" src="/backend/images/dummy-image.jpg">
                                                            </label>
                                                        </div>
                                                    </div> -->
                                                    <h4 class="my-3 label-ar-checkboximage"></h4>
                                                    <div class="options-ar-checkboximage option-grid-view-ar"></div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
    </div>
</div>
