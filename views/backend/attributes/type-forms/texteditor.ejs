<div class="selected-data mb-4 attribute-texteditor-data" data-type="texteditor" style="display: none;">
    <div class="row">
        <div class="col-12 col-md-7 texteditor-form">
            <div class="previwe-btn-box" data-type="texteditor">
                <a href="javascript:;" class="btn btn-info btn-view perviewtextWithLabel" id="perviewtextWithLabel" title="<%= trans.global.preview %>">
                    <i class="fas fa-eye"></i>
                </a>
            </div>
            
            <div class="lang-card-box">
                <div class="title-box">
                    <h3 class="mt-0">
                        <%= trans.global.label %>
                    </h3>
                </div>
                <div class="lang-form-input-group">
                    <div class="row w-100">
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                                <input
                                    class="form-control"
                                    type="text"
                                    name="label_en"
                                    id="texteditor_label_en"
                                    value="<%= attribute?.label?.en || '' %>"
                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.english +')' %>"
                                />
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-group">
                                <input
                                    class="form-control"
                                    type="text"
                                    name="label_ar"
                                    id="texteditor_label_ar"
                                    value="<%= attribute?.label?.ar || '' %>"
                                    placeholder="<%= trans.global.enter_your +' '+ trans.global.label +' ('+ trans.global.arabic +')' %>"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-5">
            <div class="preview-data preview-text-data" data-type="texteditor" style="display: none;">
                <fieldset>
                    <legend><%= trans.global.preview %></legend>
                    <div class="mb-4">
                        <div class="lang-card-box">
                            <div class="lang-form-input-group">
                                <div class="row w-100">
                                    <div class="col-12 col-md-12">
                                        <div class="form-group">
                                            <div class="lang-title-box">
                                                <%= trans.global.english %>
                                            </div>
                                            
                                            <label class="form-label text-left" for="texteditor_value_attribute_en"></label>
                                            <div class="description_editor richtexteditor" id="texteditor_value_attribute_en"></div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-12 mt-4">
                                        <div class="form-group">
                                            <div class="lang-title-box">
                                                <%= trans.global.arabic %>
                                            </div>
                                        
                                            <label class="form-label text-left" for="texteditor_value_attribute_ar"></label>
                                            <div class="description_editor1 richtexteditor" id="texteditor_value_attribute_ar"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
    </div>
</div>