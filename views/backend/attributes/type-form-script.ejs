    $(this).on('change', function (e) {
      imgWrap = $(this).closest('.upload__box').find('.upload__img-wrap');
      var maxLength = $(this).attr('data-max_length');

      var files = e.target.files;
      var filesArr = Array.prototype.slice.call(files);
      var iterator = 0;
      filesArr.forEach(function (f, index) {

        if (!f.type.match('image.*')) {
          return;
        }

        if (imgArray.length > maxLength) {
          return false
        } else {
          var len = 0;
          for (var i = 0; i < imgArray.length; i++) {
            if (imgArray[i] !== undefined) {
              len++;
            }
          }
          if (len > maxLength) {
            return false;
          } else {
            imgArray.push(f);

            var reader = new FileReader();
            reader.onload = function (e) {
              var html = "<div class='upload__img-box'><div style='background-image: url(" + e.target.result + ")' data-number='" + $(".upload__img-close").length + "' data-file='" + f.name + "' class='img-bg'><div class='upload__img-close'></div></div></div>";
              imgWrap.append(html);
              iterator++;
            }
            reader.readAsDataURL(f);
          }
        }
      });
    });
  });

  $('body').on('click', ".upload__img-close", function (e) {
    var file = $(this).parent().data("file");
    for (var i = 0; i < imgArray.length; i++) {
      if (imgArray[i].name === file) {
        imgArray.splice(i, 1);
        break;
      }
    }
    $(this).parent().parent().remove();
  });
}

$(function () {
    $('.formFileRadioImage').FancyFileUpload({
    params: {
        action: 'fileuploader'
    },
    maxfilesize: 1000000,
    accept: '.jpg,.jpeg,.png,.gif'
    });
});

function handleCheckboxChange($checkbox) {
    const type = $checkbox.data('type');
    const $parentWrapper = $checkbox.closest(`.check-image-size-${type}`);
    const $hideCheckboxDiv = $parentWrapper.siblings('.hidecheckbox');

    if ($checkbox.is(':checked')) {
        $hideCheckboxDiv.hide();
        $hideCheckboxDiv.find('input[type="file"]').val('');
        $parentWrapper.removeClass('col-md-6').addClass('col-md-12');
    } else {
        $hideCheckboxDiv.show();
        $parentWrapper.removeClass('col-md-12').addClass('col-md-6');
    }
}

$(document).ready(function () {
    $('.form-check-input[data-type]').each(function () {
        handleCheckboxChange($(this));
    });
});

$(document).on("change", ".form-check-input[data-type]", function () {
    handleCheckboxChange($(this));
});

</script>