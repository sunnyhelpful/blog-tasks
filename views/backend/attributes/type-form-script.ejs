            const inputType = type === 'radioimage' ? 'radio' : 'checkbox';

            $optionEnInputArray.each(function (index) {
                const enInput = this;
                const arInput = $optionArInputArray.eq(index)[0];
                const $enInput = $(enInput);
                const $arInput = $(arInput);

                const isSameImageChecked = $enInput.closest('.copy-file-upload-data').find('input[type="checkbox"]').prop('checked');

                const fileEn = enInput.files ? enInput.files[0] : null;
                const fallbackEnImage = $enInput.data('existing-image');

                const fileAr = arInput.files ? arInput.files[0] : null;
                const fallbackArImage = $arInput.data('existing-image');

                function appendImagePreview($container, imageUrl, index, lang) {
                    $container.append(`
                        <div class="form-check w-fit main-img-checkbox">
                            <div class="img-checkbox">
                                <input class="main-img-cover form-check-input" id="img-${type}-${lang}-${index + 1}" type="${inputType}" name="${inputType}-image-option-${lang}">
