    /* preview after only fill with their label */
    $(document).on('click', '.perviewtextWithLabel', function (e) {
        e.preventDefault();

        const $parentContainer = $(this).closest('#attribute-type-form');
        const type = $(this).closest('.previwe-btn-box').data('type');
        let $container = $parentContainer.find(`.attribute-${type}-data`);
        $container.find('.invalid-feedback').remove();
        $container.find('.is-invalid').removeClass('is-invalid');

        
        if ((type === 'text') || (type == 'number') || (type == 'date') || (type == 'textarea') || (type == 'googlemap') || (type == 'texteditor') || (type == 'singleimageuploader') || (type == 'multipleimageuploader')) {
            multiplesPreviewAppend($container);
        } else if(type == 'boolean'){
            booleanAppend($container);
        } else if((type == 'radio') || (type == 'checkbox') || (type == 'radioimage') || (type == 'checkboximage') || (type == 'toggleswitchtitle') || (type == 'toggleswitchtitleinput')) {
            radioAndCheckboxAppend($container);
        } else if((type == 'radioimagetitle') || (type == 'checkboximagetitle')){
            radioAndCheckboxWithTitleAndImageAppend($container);
        } else if((type == 'singleselectdropdown') || (type == 'singleselectdropdownwithsearch') || (type === 'multipleselectdropdown') || (type === 'multipleselectdropdownwithsearch')){
            selectAndTogglePreviewAppend($container);
        }
    });

    function multiplesPreviewAppend(container){
        let type = container.data('type');
        const $labelEnInput = container.find('input[name="label_en"]');
        const $labelArInput = container.find('input[name="label_ar"]');
        const $placeholderEnInput = container.find('input[name="placeholder_en"]');
        const $placeholderArInput = container.find('input[name="placeholder_ar"]');

        const labelEn = $labelEnInput.val().trim();
        const labelAr = $labelArInput.val().trim();


        const placeholderEn = $placeholderEnInput.length ? $placeholderEnInput.val().trim() : null;
        const placeholderAr = $placeholderArInput.length ? $placeholderArInput.val().trim() : null;

        let hasError = false;
        let $preview = null;
        if (!labelEn) {
            $labelEnInput
                .addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.global.label
                }) + ' (' + trans.global.english + ')' %></span>`);
            hasError = true;
        }

        if (!labelAr) {
            $labelArInput
                .addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.global.label
                }) + ' (' + trans.global.arabic + ')' %></span>`);
            hasError = true;
        }

        if ($placeholderEnInput.length && !placeholderEn) {
            $placeholderEnInput
                .addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.global.placeholder
                }) + ' (' + trans.global.english + ')' %></span>`);
            hasError = true;
        }

        if ($placeholderArInput.length && !placeholderAr) {
            $placeholderArInput
                .addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                    attribute: trans.global.placeholder
                }) + ' (' + trans.global.arabic + ')' %></span>`);
            hasError = true;
        }

        if (hasError) return;

        $preview = $('.preview-text-data[data-type="' + type + '"]');

        $preview.find(`label[for="${type}_value_attribute_en"]`).text(labelEn);
        $preview.find(`label[for="${type}_value_attribute_ar"]`).text(labelAr);

        if ($placeholderEnInput.length && placeholderEn) {
            $preview.find(`#${type}_value_attribute_en`).attr('placeholder', placeholderEn);
        }
        if ($placeholderArInput.length && placeholderAr) {
            $preview.find(`#${type}_value_attribute_ar`).attr('placeholder', placeholderAr);
        }

        $preview.slideDown();
    }

