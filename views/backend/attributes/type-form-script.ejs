                <div class="form-check w-fit">
                    <input class="form-check-input" id="flexRadioDefault4" type="radio" name="flexRadioDefault-ar" checked>
                    <label class="form-check-label" for="flexRadioDefault4">${option2Ar}</label>
                </div>
