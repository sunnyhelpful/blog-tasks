<script>
$(document).ready(function () {
    const attriTypeVal = `<%= attribute?.type || '' %>`;
    const isEditMode = !!attriTypeVal;

    if (isEditMode) {
        setTimeout(function () {
            $('#attrType').val(attriTypeVal).trigger('change');
        }, 100);
    }

    $(document).on('change', '#attrType', function () {
        const selected = $(this).val();
        $('.selected-data').hide();

        if (selected) {
            if (isEditMode) {
                if (selected !== attriTypeVal) {
                    clearFormData(selected);
                }
            } else {
                clearFormData(selected);
            }

            $(`.selected-data[data-type="${selected}"]`).show();

            if (
                selected === 'radioimage' ||
                selected === 'radioimagetitle' ||
                selected === 'checkboximage' ||
                selected === 'checkboximagetitle'
            ) {
                if (!isEditMode) {
                    $(`.selected-data[data-type="${selected}"]`).find('input[type="checkbox"]').prop('checked', true).trigger('change');
                } else {
                    if (selected !== attriTypeVal) {
                        $(`.selected-data[data-type="${selected}"]`).find('input[type="checkbox"]').prop('checked', true).trigger('change');
                    }
                }
            }
        }
    });

    function clearFormData(type) {
        const $parent = $(`.attribute-${type}-data`);

        if ($parent.length === 0) return;

        $parent.find('.invalid-feedback').remove();
        $parent.find('.is-invalid').removeClass('is-invalid');

        $parent.find('input[type="text"], input[type="number"], textarea').val('');
        $parent.find('input[type="file"]').val('');
        $parent.find('input[type="checkbox"], input[type="radio"]').prop('checked', false);

        $parent.find('select').each(function () {
            $(this).val(null).trigger('change');
        });

        $parent.find('.preview-text-data').hide();
        $parent.find(`.label-en-${type}`).text('');
        $parent.find(`.label-ar-${type}`).text('');
        $parent.find(`.options-en-${type}`).html('');
        $parent.find(`.options-ar-${type}`).html('');
        $parent.find('.selected-data').hide();
    }

