    function radioAndCheckboxWithTitleAndImageAppend(container) {
        const type = container.data('type');
        
        const $labelEnInput = container.find('input[name="label_en"]');
        const $labelArInput = container.find('input[name="label_ar"]');
        const $optionEnTitleInputArray = container.find('input[name="option_title_en[]"]');
        const $optionArTitleInputArray = container.find('input[name="option_title_ar[]"]');
        const $optionEnImageInputArray = container.find('input[name="option_en[]"]');
        const $optionArImageInputArray = container.find('input[name="option_ar[]"]');

        const labelEn = $labelEnInput.val().trim();
        const labelAr = $labelArInput.val().trim();

        let optionsEnTitle = [];
        let optionsArTitle = [];
        let optionsEnImage = [];
        let optionsArImage = [];

        $optionEnTitleInputArray.each(function () {
            optionsEnTitle.push($(this).val().trim());
        });
        $optionArTitleInputArray.each(function () {
            optionsArTitle.push($(this).val().trim());
        });

        $optionEnImageInputArray.each(function () {
            optionsEnImage.push({
                file: this.files ? this.files[0] : null,
                existingImage: $(this).data('existing-image')
            });
        });

        $optionArImageInputArray.each(function (index) {
            const $arInput = $(this);
            const $enInput = $optionEnImageInputArray.eq(index);
            const $sameImageCheckbox = $enInput.closest('.copy-file-upload-data').find('input[type="checkbox"]');

            if ($sameImageCheckbox.length && $sameImageCheckbox.prop('checked')) {
                optionsArImage.push({
                    file: $enInput[0].files ? $enInput[0].files[0] : null,
                    existingImage: $enInput.data('existing-image'),
                    isSame: true
                });
            } else {
                optionsArImage.push({
                    file: this.files ? this.files[0] : null,
                    existingImage: $arInput.data('existing-image'),
                    isSame: false
                });
            }
        });

        container.find('.invalid-feedback').remove();
        container.find('.is-invalid').removeClass('is-invalid');

        let hasError = false;
        let $preview = null;

        if (!labelEn) {
            $labelEnInput.addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                        attribute: trans.global.label
                    }) + ' (' + trans.global.english + ')' %></span>`);
            hasError = true;
        }

        if (!labelAr) {
            $labelArInput.addClass('is-invalid')
                .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                        attribute: trans.global.label
                    }) + ' (' + trans.global.arabic + ')' %></span>`);
            hasError = true;
        }

        optionsEnTitle.forEach((title, index) => {
            if (!title) {
                $optionEnTitleInputArray.eq(index).addClass('is-invalid');
                $optionEnTitleInputArray.eq(index).after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                        attribute: trans.global.option
                    }) + ' (' + trans.global.english + ')' %></span>`);
                hasError = true;
            }
        });

        optionsArTitle.forEach((title, index) => {
            if (!title) {
                $optionArTitleInputArray.eq(index).addClass('is-invalid');
                $optionArTitleInputArray.eq(index).after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                        attribute: trans.global.option
                    }) + ' (' + trans.global.arabic + ')' %></span>`);
                hasError = true;
            }
        });

        optionsEnImage.forEach((image, index) => {
            const $input = $optionEnImageInputArray.eq(index);
            const inputType = $input.closest('.copy-file-upload-data').data('type');
            const isImageType = inputType === 'radioimagetitle' || inputType === 'checkboximagetitle';

            if (isImageType) {
                if (!image.file && !image.existingImage) {
                    $input.addClass('is-invalid')
                        .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                        attribute: trans.global.option
                    }) + ' (' + trans.global.english + ')' %></span>`);
                    hasError = true;
                }
            }
        });

        // Fixed: Changed optionsArImage.each to optionsArImage.forEach
        optionsArImage.forEach((image, index) => {
            const $arInput = $optionArImageInputArray.eq(index);
            const $enInput = $optionEnImageInputArray.eq(index);
            const inputType = $enInput.closest('.copy-file-upload-data').data('type') || container.data('type');
            const isImageType = inputType === 'radioimagetitle' || inputType === 'checkboximagetitle';

            if (isImageType && image.isSame) return;

            if (isImageType) {
                if (!image.file && !image.existingImage) {
                    $arInput.addClass('is-invalid')
                        .after(`<span class="invalid-feedback d-block"><%= t(trans.validation.client_side_validate.required_message, {
                            attribute: trans.global.option_image
                        }) + ' (' + trans.global.arabic + ')' %></span>`);
                    hasError = true;
                }
            }
        });

        if (hasError) {
            container.find('.lang-form-input-group').addClass('mb-3');
            return false;
        } else {
            container.find('.lang-form-input-group').removeClass('mb-3');
        }

        $preview = $(`.preview-text-data[data-type="${type}"]`);

        $preview.find(`.label-en-${type}`).text(labelEn);
        $preview.find(`.label-ar-${type}`).text(labelAr);

        $preview.find(`.options-en-${type}`).html('');
        $preview.find(`.options-ar-${type}`).html('');

        if (type === 'radioimagetitle' || type === 'checkboximagetitle') {
            const inputType = type === 'radioimagetitle' ? 'radio' : 'checkbox';

            optionsEnTitle.forEach((enTitle, index) => {
                const enImage = optionsEnImage[index];
                const arTitle = optionsArTitle[index];
                const arImage = optionsArImage[index];

                const processImage = (imageData, title, lang) => {
                    const imageUrl = imageData.file ? 
                        URL.createObjectURL(imageData.file) : 
                        imageData.existingImage;

                    if (!imageUrl) return;

                    $preview.find(`.options-${lang}-${type}`).append(`
                        <div class="form-check w-fit main-img-checkbox">
                            <div class="img-checkbox">
                                <input class="main-img-cover form-check-input" 
                                    id="img-${type}-${lang}-${index}" 
                                    type="${inputType}" 
                                    name="${inputType}-${lang}-group">
                                <label class="form-check-label mb-0" for="img-${type}-${lang}-${index}">
                                    <img class="img-100" src="${imageUrl}" alt="${title}">
                                    <span>${title}</span>
                                </label>
                            </div>
                        </div>
                    `);
                };

                // English version
                processImage(enImage, enTitle, 'en');

                // Arabic version
                const arImageData = arImage.isSame ? enImage : arImage;
                processImage(arImageData, arTitle, 'ar');
            });
        }

        $preview.show();
    }


