    /* For label on key up start */
    $(document).on('input', 'input[name="label_en"], input[name="label_ar"]', function () {
        const $container = $(this).closest('.lang-form-input-group');
        const $parentSelected = $container.closest('.selected-data');
        const type = $parentSelected.data('type');

        const $preview = $('.preview-text-data[data-type="' + type + '"]');
        if ($preview.is(':visible')) {
            const labelEn = $container.find('input[name="label_en"]').val().trim();
            const labelAr = $container.find('input[name="label_ar"]').val().trim();
            updatePreviewContent(type, labelEn, labelAr, $preview);
        }
    });

    function updatePreviewContent(type, labelEn, labelAr, $preview) {
        switch (type) {
            case 'text':
            case 'number':
            case 'date':
            case 'googlemap':
            case 'texteditor':
            case 'textarea':
            case 'singleimageuploader':
            case 'multipleimageuploader':
            case 'singleselectdropdown':
            case 'singleselectdropdownwithsearch':
            case 'multipleselectdropdown':
            case 'multipleselectdropdownwithsearch':
                $preview.find(`label[for="${type}_value_attribute_en"]`).text(labelEn);
                $preview.find(`label[for="${type}_value_attribute_ar"]`).text(labelAr);
                /* $preview.find('input[name$="_en"]').attr('placeholder', labelEn);
                $preview.find('input[name$="_ar"]').attr('placeholder', labelAr); */
                break;

            case 'boolean':
            case 'checkbox':
            case 'checkboximage':
            case 'checkboximagetitle':
            case 'radio':
            case 'radioimage':
            case 'radioimagetitle':
            case 'toggleswitchtitle':
            case 'toggleswitchtitleinput':
                $preview.find(`.label-en-${type}`).text(labelEn);
                $preview.find(`.label-ar-${type}`).text(labelAr);
                break;

            default:
                console.warn('Unsupported preview type: ' + type);
                break;
        }
    }
    /* End for label on key up */


    /* Start action btn append html */
    function updateButtons(type = null) {
        if(type){
            let boxes = $(`.${type}-options-wrapper .option-box`);
            if(type == 'checkboximagetitle' || type == 'radioimagetitle'){
                boxes =  $(`.${type}-options-wrapper`).find('.clone-data-main')
            }
            boxes.find('.action-group').remove();

            boxes.each(function (index) {
                const isLast = index === boxes.length - 1;
                const btnGroup = $('<div class="action-group"></div>');

                $(this).find('.title-box h3').text('<%= trans.global.option %> ' + (index + 1));

                if (isLast && boxes.length > 1) {
                    btnGroup.append(`<button type="button" class="action-btn remove-btn btn btn-secondary" data-type=${type}>−</button>`);
                    btnGroup.append(`<button type="button" class="action-btn add-btn btn btn-primary" data-type=${type}>＋</button>`);
                } else if (isLast) {
                    btnGroup.append(`<button type="button" class="action-btn remove-btn btn btn-secondary" data-type=${type}>−</button>`);
                    btnGroup.append(`<button type="button" class="action-btn add-btn btn btn-primary" data-type=${type}>＋</button>`);
                } else {
                    btnGroup.append(`<button type="button" class="action-btn remove-btn btn btn-secondary" data-type=${type}>−</button>`);
                    btnGroup.append(`<button type="button" class="action-btn add-btn btn btn-primary hidebtn" data-type=${type}>＋</button>`);
                }

                $(this).append(btnGroup);
            });
        } else {
            console.log('Type not found!');
        }
    }

    $(document).on('click', '.add-btn', function () {
        const $this = $(this);
        const type = $this.data('type');
        let count = null;

        const $target = $(`.align-box-wrap[data-type="${type}"]`);
        if (!$target.hasClass('align-box-large-wrap')) {
            $target.addClass('align-box-large-wrap');
        }
        
        if(type == 'checkboximagetitle' || type == 'radioimagetitle'){


            const $wrapper = $this.closest(`.${type}-options-wrapper`);
            const $lastLangCard = $wrapper.find('.clone-data-main').last();

            count = parseInt($lastLangCard.attr('data-count')) || 1;
            count += 1;

            const $clone = $lastLangCard.clone();
            $clone.find('input[type="text"], input[type="file"]').val('');

            $clone.find('input[type="text"]').each(function () {
                const $input = $(this);
                const nameAttr = $input.attr('name') || '';
                
                if (nameAttr.includes('option_title_en') || nameAttr.includes('option_title_ar')) {
                    const lang = nameAttr.includes('_ar') ? 'ar' : 'en';
                    const newId = `${type}_option_title_${lang}_${count}`;
                    $input.attr('id', newId);
                }
            });

            $clone.find('input[type="file"]').each(function () {
                const $input = $(this);
                if ($input.is('[data-existing-image]')) {
                    $(this).removeAttr('data-existing-image');
                    $(this).removeAttr('data-existing-image-for-save');
                }
                const lang = $input.attr('name').includes('_ar') ? 'ar' : 'en';
                const newId = `${type}_option_image_${lang}_${count}`;
                $input.attr('id', newId);
            });
            $clone.find('input[type="radio"]').each(function () {
                const newId = `${type}_imagecloneradio_${count}`;
                $(this).attr('id', newId);
            });

            $clone.find('input[type="checkbox"]').each(function () {
                const newCheckboxVal = `${type}_imageclonecheck_${count}`;
                $(this).attr('id', newCheckboxVal);
                $(this).attr('name', newCheckboxVal);
            });
            $clone.find('.title-box h3').text('<%= trans.global.option %> ' + count);
            $clone.attr('data-count', count);
            $lastLangCard.after($clone);
        } else {
            /* 
                const $lastBox = $(`.${type}-options-wrapper .${type}-clone-wrap .option-box:last`);
                const $clone = $lastBox.clone();
                $clone.find('input').val('');
                $(`.${type}-options-wrapper .${type}-clone-wrap`).append($clone);
            */
            const $wrapper = $(`.${type}-options-wrapper`);
            const $lastBox = $wrapper.find(`.${type}-clone-wrap .option-box:last`);

            let count = parseInt($lastBox.attr('data-count')) || 1;
            count += 1;

            const $clone = $lastBox.clone();

            $clone.find('input[type="text"], input[type="file"]').val('');

            $clone.find('input[type="text"]').each(function () {
                const $input = $(this);
                const nameAttr = $input.attr('name') || '';

                if (nameAttr.includes('option_en')) {
                    $input.attr('id', `${type}_option_en_${count}`);
                } else if (nameAttr.includes('option_ar')) {
                    $input.attr('id', `${type}_option_ar_${count}`);
                }
            });

            $clone.find('input[type="file"]').each(function () {
                const $input = $(this);
                if ($input.is('[data-existing-image]')) {
                    $(this).removeAttr('data-existing-image');
                    $(this).removeAttr('data-existing-image-for-save');
                }
                const lang = $input.attr('name').includes('_ar') ? 'ar' : 'en';
                const newId = `${type}_option_image_${lang}_${count}`;
                $input.attr('id', newId);
            });

            $clone.find('input[type="checkbox"]').each(function () {
                const newVal = `${type}_imageclonecheck_${count}`;
                $(this).attr('id', newVal);
                $(this).attr('name', newVal);
            });

            $clone.find('input[type="radio"]').each(function () {
                const newId = `${type}_imagecloneradio_${count}`;
                $(this).attr('id', newId);
            });

            $clone.find('.title-box h3').text('<%= trans.global.option %> ' + count);
            $clone.attr('data-count', count);
            $wrapper.find(`.${type}-clone-wrap`).append($clone);
            updateButtons(type);
        }

        updateButtons(type);
    });

    $(document).on('click', '.remove-btn', function () {
        const type = $(this).data('type');
        const $targetWrapper = $(this).closest(`.${type}-options-wrapper`);
        
        if (type === 'checkboximagetitle' || type === 'radioimagetitle') {
            $(this).closest('.clone-data-main').remove();

            const $remainingBoxes = $targetWrapper.find('.clone-data-main');
            console.log($remainingBoxes.length);

            if ($remainingBoxes.length === 1) {
                $targetWrapper.find('.lang-form-input-group').removeClass('align-box-large-wrap');
                $remainingBoxes.find('.remove-btn').hide();
            } else {
                $remainingBoxes.find('.remove-btn').show();
            }
        } else {
            const $allRemoveBtns = $(`.remove-btn[data-type="${type}"]`);
            
            if ($allRemoveBtns.length === 1) {
                $(this).closest('.option-box').find('input').val('');
                return;
            }
            
            $(this).closest('.option-box').remove();
            const $remainingBoxes = $targetWrapper.find('.option-box');
            if ($remainingBoxes.length === 1) {
                $targetWrapper.find('.lang-form-input-group').removeClass('align-box-large-wrap');
                $remainingBoxes.find('.remove-btn').hide();
            } else {
                $remainingBoxes.find('.remove-btn').show();
            }
        }

        updateButtons(type);
        const $remainingBoxes = $targetWrapper.find('.option-box');
        if ($remainingBoxes.length === 1) {
            $targetWrapper.find('.lang-form-input-group').removeClass('align-box-large-wrap');
            $remainingBoxes.find('.remove-btn').hide();
        } else {
            $remainingBoxes.find('.remove-btn').show();
        }
    });

