<% title = 'Posts' %>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h2>Posts</h2>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/admin/dashboard">
                            <i class="iconly-Home icli svg-color"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/admin/blogs">Posts</a>
                    </li>
                    <li class="breadcrumb-item active">List</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
  <div class="row">
    <div class="col-sm-12">
      <div class="card">
        
        <div class="card-header card-no-border d-flex justify-content-between align-items-center">
          <div>            
            <h3>Post List</h3>
            <!-- <p class="desc mb-0 mt-1">All blog entries</p> -->
          </div>

          <% if (userInfo.permissions.includes("create_blog")) { %>
            <div class="btn-showcase d-flex justify-content-end">
                <a href="/admin/blog/create" title="Create" class="btn btn-pill btn-success" id="btnAddBlog">
                  Create
                </a>
            </div>
          <% } %>

        </div>

        <div class="card-body pt-0"> 
          <div class="table-responsive theme-scrollbar">
            <table class="table table-lg display blogsTable" id="row_create" style="width:100%">
              <thead>
                  <tr>
                    <th>#</th>
                    <th data-data="title">Title</th>
                    <th data-data="createdAt">Created At</th>

                    <% if (
                      userInfo.permissions.includes("view_blog") || 
                      userInfo.permissions.includes("edit_blog") || 
                      userInfo.permissions.includes("delete_blog")
                    ) { %>
                      <th data-data="action">Action</th>
                    <% } else { %>
                      <th></th>
                    <% } %>

                  </tr>
              </thead>
              <tbody>
                  <!-- Data will be loaded via AJAX -->
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
<%- include('./script') %>