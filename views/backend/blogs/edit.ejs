<% title = 'Edit Blog' %>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h2>Blogs</h2>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/admin/dashboard">
                            <i class="iconly-Home icli svg-color"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/admin/blogs">Blogs</a>
                    </li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="edit-profile">
        <div class="row">
            <div class="col-xl-12">
                <form class="card" id="blogData" action="/admin/blog/store" method="POST">
                    <div class="card-header card-no-border pb-0">
                        <h3 class="card-title mb-0">Edit Blog</h3>
                    </div>

                    <%- include('./_form') %>

                    <div class="card-footer text-end d-flex justify-content-end gap-2">
                        <!-- Cancel Button -->
                        <a href="/admin/blogs" class="btn btn-secondary">
                            Cancel
                        </a>

                        <!-- Save & Continue Editing Button -->
                        <button class="btn btn-info" type="submit" name="save_continue" value="1">
                            Save & Continue
                        </button>

                        <!-- Save Button -->
                        <button class="btn btn-primary" type="submit">
                            Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('./script') %>