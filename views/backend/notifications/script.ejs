<script>
$(document).ready(function() {
    const table = $('.notificationsTable').DataTable({
        processing: true,
        serverSide: true,
        deferRender: true,
        scrollY: '605px',
        scrollCollapse: true, 
        scroller: {
            loadingIndicator: true,
            displayBuffer: 10,
        },
        order: [[3, 'desc']],
        language: languageConfig,
        ajax: function(data, callback, settings) {
            $.ajax({
                url: '/admin/notifications',
                type: 'GET',
                dataType: 'json',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                data: {
                    draw: data.draw,
                    start: data.start,
                    length: data.length,
                    search: data.search,
                    order: data.order,
                    columns: data.columns
                },
                success: function(response) {
                    const resultData = response.data;
                    callback({
                        draw: response.draw,
                        recordsTotal: response.recordsTotal,
                        recordsFiltered: response.recordsFiltered,
                        data: resultData
                    });
                },
                error: function(xhr, error, thrown) {
                    console.error("AJAX error:", error, xhr.responseText);
                }
            });
        },
        columns: [
            { 
                data: null,
                render: function(data, type, row, meta) {
                    return meta.row + meta.settings._iDisplayStart + 1;
                }
            },
            { 
                data: 'title', 
                render: function(data, type, row) {
                    let dataValue = data ? data : `<%= trans.global.not_available %>`;
                    return dataValue.length > 20 ? dataValue.substring(0, 20) + '...' : dataValue;
                }
            },
            {
                data: 'isRead',
                render: function(data) {
                    let statusClass = data ? 'bg-success' : 'bg-warning';
                    let statusText = data ? 'Read' : 'Unread';
                    return `<span class="badge ${statusClass}">${statusText}</span>`;
                }
            },
            { 
                data: 'createdAt',
                render: function(data) {
                    if (!data) return `<%= trans.global.not_available %>`;
                    return new Date(data).toLocaleString();
                }
            },
            {
                data: 'id',
                orderable: false,
                render: function(data, type, row) {
                    let html = '<div class="d-flex gap-1">';
                    <% if (userInfo.permissions.includes('view_notification')) { %>
                        html += `<a href="/admin/notification/${data}" class="btn btn-sm btn-info btn-view notificationUser">
                                    <i class="fas fa-eye"></i>
                                </a>`;
                    <% } %>
                    <% if (userInfo.permissions.includes('delete_notification')) { %>
                        html += `<a href="javascript:;" class="btn btn-sm btn-danger btn-delete" data-id="${data}" onclick="confirmAction('delete', '/admin/notification/${data}/delete', '/admin/notifications', 'DELETE')">
                                    <i class="fas fa-trash"></i>
                                </a>`;
                    <% } %>
                    <% if (userInfo.permissions.includes('mark_notification_read')) { %>
                        if (!row.isRead) {
                            html += `<a href="javascript:;" class="btn btn-sm btn-info btn-read markAsRead" title="${`<%= trans.cruds.NOTIFICATION.heading.mark_as_read %>`}" data-id="${data}">
                                    <i class="fas fa-envelope-open"></i> 
                                </a>`;
                        }
                    <% } %>
                    html += `</div>`;
                    return html;
                }
            }
        ]
    });

    $(document).on("click", ".markAsRead", function (e) {
        e.preventDefault();
        const $this = $(this);
        const id = $this.data('id');

        $.ajax({
            url: `/admin/notification/mark-read/${id}`,
            type: 'POST',
            success: function (response) {
                if (response.status) {
                    $('.notificationsTable').DataTable().ajax.reload(null, false);
                    showNotificationPopup(response.message, 'success');
                } else {
                    showNotificationPopup(response.message, 'error');
                }
            },
            error: function (xhr) {
                showNotificationPopup("Oops, something went wrong. Please try again", 'error');
            }
        });
    });
});


</script>