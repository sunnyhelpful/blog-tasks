<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.querySelector('.li-post-input')?.addEventListener('click', function() {
    this.style.borderColor = '#0a66c2';
  });

  document.querySelectorAll('.post-action-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const icon = this.querySelector('i');
      if (icon && (icon.classList.contains('bi-hand-thumbs-up') || icon.classList.contains('bi-hand-thumbs-up-fill'))) {
        if (this.dataset.liked === '1') {
          this.dataset.liked = '0';
          this.style.color = '';
          icon.classList.replace('bi-hand-thumbs-up-fill', 'bi-hand-thumbs-up');
          if(this.lastChild) this.lastChild.textContent = ' Like';
        } else {
          this.dataset.liked = '1';
          this.style.color = '#0a66c2';
          icon.classList.replace('bi-hand-thumbs-up', 'bi-hand-thumbs-up-fill');
          if(this.lastChild) this.lastChild.textContent = ' Liked';
        }
      }
    });
  });

  document.querySelectorAll('.connect-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      if (this.dataset.sent === '1') return;
      this.dataset.sent = '1';
      this.innerHTML = '<i class="bi bi-check2" style="font-size:11px;"></i> Pending';
      this.style.color = 'rgba(0,0,0,0.5)';
      this.style.borderColor = 'rgba(0,0,0,0.2)';
    });
  });
</script>
</body>
</html>