<% title = trans.auth.messages.reset_password.title + ' - ' + companyInfo.NAME %>
<div class="row m-0">
    <div class="col-12 p-0">    
        <div class="login-card login-dark">
            <div>
                <a class="logo" href="javascript:;">
                    <!-- <img class="img-fluid for-light m-auto" src="/backend/images/logo/logo1.png" alt="looginpage">
                    <img class="img-fluid for-dark" src="/backend/images/logo/logo-dark.png" alt="logo"> -->
                    <h3><%= companyInfo.NAME || 'Kanzy' %></h3>
                  </a>
                <div class="login-main"> 
                    <form class="theme-form" id="resetPasswordForm" action="<%- '/admin/reset-password' %>" method="POST">
                        <h2 class="text-left"><%= trans.auth.messages.reset_password.heading %></h2>
                        <p class="text-left"><%= trans.auth.messages.reset_password.subheading %></p>
                        
                        <%- include('./partials/language-selector') %>
                        
                        <!-- Password field -->
                        <div class="form-group">
                            <label class="col-form-label"><%= trans.auth.AUTH.fields.new_password %></label>
                            <div class="input-group position-relative">
                                <input class="form-control password-field" type="password" name="password" id="password" placeholder="*********" autocomplete="off">
                                <button class="btn btn-outline-secondary toggle-password top-0 mt-2" type="button">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Confirm Password field -->
                        <div class="form-group">
                            <label class="col-form-label"><%= trans.auth.AUTH.fields.confirm_password %></label>
                            <div class="input-group  position-relative">
                                <input type="password" class="form-control password-field"  placeholder="**********" id="confirmPassword" name="password_confirmation" autocomplete="off">                                
                                <button class="btn btn-outline-secondary toggle-password top-0 mt-2" type="button">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="form-group mb-0 checkbox-checked">
                            <button class="btn btn-primary btn-block w-100 mt-3" type="submit"><%= trans.auth.messages.reset_password.btn_title %></button>
                        </div>

                        <p class="mt-4 mb-0 text-center"><%= trans.auth.messages.reset_password.remember_your_password %> <a class="ms-2" href="/admin/login"><%= trans.auth.messages.login.btn_title %></a></p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>  