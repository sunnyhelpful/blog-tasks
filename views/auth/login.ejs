<% title = trans.auth.messages.login.title + ' - ' + companyInfo.NAME %>

<div class="row m-0">
  <div class="col-12 p-0">    
    <div class="login-card login-dark">
      <div>
        <div>
          <a class="logo" href="javascript:;">
            <!-- <img class="img-fluid for-light m-auto" src="/backend/images/logo/logo1.png" alt="looginpage">
            <img class="img-fluid for-dark" src="/backend/images/logo/logo-dark.png" alt="logo"> -->
            <h3><%= companyInfo.NAME %></h3>
          </a>
        </div>
        <div class="login-main"> 
          <form class="theme-form" id="loginForm" action="<%- '/admin/login' %>" method="POST">
            <h2 class="text-left"><%= trans.auth.messages.login.heading %></h2>
            <p class="text-left"><%= trans.auth.messages.login.subheading %></p>

            <%- include('./partials/language-selector') %>

            <div class="form-group">
              <label class="col-form-label"><%= trans.auth.AUTH.fields.email_address %></label>
              <input type="email" class="form-control" id="email" placeholder="<%= trans.global.enter_your +' '+ trans.auth.AUTH.fields.email_address || 'Email Address' %>" name="email" autofocus="off" value="">
            </div>
            <div class="form-group">
              <label class="col-form-label"><%= trans.auth.AUTH.fields.password %></label>
              <div class="input-group  position-relative">
                <input class="form-control password-field" type="password" name="password"  autofocus="off" placeholder="<%= trans.global.enter_your + ' ' + trans.auth.AUTH.fields.password %>">
                <button class="btn btn-outline-secondary toggle-password top-0 mt-2" type="button">
                  <i class="fa-solid fa-eye"></i>
                </button>
              </div>
            </div>
            <div class="form-group mb-0 checkbox-checked">
              <!-- <div class="form-check checkbox-solid-info">
                <input class="form-check-input" id="solid6" type="checkbox">
                <label class="form-check-label" for="solid6">Remember password</label>
              </div> -->
              <a class="link" href="/admin/forgot-password"><%= trans.auth.messages.forgot_password.title %></a>
              <div class="text-end mt-3">
                <button class="btn btn-primary btn-block w-100" type="submit"><%= trans.auth.messages.login.btn_title %></button>
              </div>
            </div>  
            </div>
            <!-- <p class="mt-4 mb-0 text-center">Don't have account?<a class="ms-2" href="/register">Create Account</a></p> -->
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
