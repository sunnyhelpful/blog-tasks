<script>
    document.addEventListener("DOMContentLoaded", function(){
        // Dropdown toggle logic
        const body = document.querySelector("body");
        body.addEventListener("click", function (event) {
            const dropdownEl = event.target.closest(".custom-dropdown");
            const dropdownMenuElement = event.target.closest(".custom-menu");
            const allMenus = document.querySelectorAll(".custom-menu");
            allMenus.forEach((menu) => menu.classList.remove("show"));

            if (!dropdownEl) return;

            const menu = dropdownEl.querySelector(".custom-menu");
            if (!dropdownMenuElement && menu) {
                menu.classList.add("show");
            }
        });
    });


     function updateOTP() {
        let value = document.getElementById('otp').value;
        value = value.replace(/\D/g, '');
        value = value.slice(0, 6);
        document.getElementById('otp').value = value;

        for (let i = 1; i <= 6; i++) {
            const digitBox = document.getElementById('digit' + i);
            digitBox.classList.remove('caret');
            digitBox.textContent = value[i - 1] || '';
        }

        const nextIndex = value.length === 0 ? 1 : value.length + 1;
        if (nextIndex <= 6) {
            document.getElementById('digit' + nextIndex).classList.add('caret');
        }
    }

    function focusOTPInput(event) {
        const otpInput = document.getElementById('otp');
        otpInput.focus();
        for (let i = 1; i <= 6; i++) {
            document.getElementById('digit' + i).classList.remove('caret');
        }
        if (event.target.classList.contains('otp-digit')) {
            event.target.classList.add('caret');
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        const otpInput = document.getElementById('otp');
        otpInput.focus(); 
        updateOTP();      
    });
    
